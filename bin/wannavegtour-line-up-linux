#!/usr/bin/env bash
# Linux variant of bin/wannavegtour-line-up for DGX Spark / generic Linux.
#
# Differences from the macOS launcher:
#   - No caffeinate (servers don't sleep; if needed use systemd-inhibit).
#   - Uses repo-local .venv/bin/python if present, else falls back to python3.
#
# Components launched (in order):
#   1. wannavegtour.line_listener  — HTTP server on 127.0.0.1:8765 (background)
#   2. tailscale funnel            — expose 8765 publicly via tailnet HTTPS
#
# State directory: ~/.hermes/run/wannavegtour/
#   - listener.pid
#   - listener.log

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
RUN_DIR="$HOME/.hermes/run/wannavegtour"
LISTEN_HOST="${WANNAVEG_LISTEN_HOST:-127.0.0.1}"
LISTEN_PORT="${WANNAVEG_LISTEN_PORT:-8765}"

mkdir -p "$RUN_DIR"
chmod 700 "$RUN_DIR"

LIST_PID_FILE="$RUN_DIR/listener.pid"
LIST_LOG_FILE="$RUN_DIR/listener.log"

# Resolve python: prefer repo venv.
if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
  PY="$REPO_ROOT/.venv/bin/python"
else
  PY="$(command -v python3 || true)"
fi

# --- pre-flight ----------------------------------------------------------------

echo "[wannavegtour-line-up-linux] pre-flight checks…"

if [ -z "$PY" ]; then
  echo "  ✗ no python3 found (and no .venv at $REPO_ROOT/.venv)" >&2
  exit 1
fi
echo "  ✓ python: $PY"

if ! command -v tailscale >/dev/null 2>&1; then
  echo "  ✗ tailscale CLI not found; install from https://tailscale.com/download" >&2
  exit 1
fi
echo "  ✓ tailscale present"

if ! PYTHONPATH="$REPO_ROOT" "$PY" -c "import wannavegtour" 2>/dev/null; then
  echo "  ✗ wannavegtour package not importable; checked $REPO_ROOT" >&2
  exit 1
fi
echo "  ✓ wannavegtour package importable"

if ! PYTHONPATH="$REPO_ROOT" "$PY" -c "from wannavegtour.config import load_config, load_line_config; load_config(); load_line_config()" 2>/dev/null; then
  echo "  ✗ credentials not loaded; check ~/.hermes/credentials/wannavegtour/{wc-api,line-bot}.json" >&2
  echo "    (debug: PYTHONPATH=$REPO_ROOT $PY -c 'from wannavegtour.config import load_line_config; load_line_config()')" >&2
  exit 1
fi
echo "  ✓ credentials loaded (WC + LINE)"

# --- 1. listener ---------------------------------------------------------------

if [ -f "$LIST_PID_FILE" ] && kill -0 "$(cat "$LIST_PID_FILE")" 2>/dev/null; then
  echo "[listener] already running (pid $(cat "$LIST_PID_FILE"))"
else
  cd "$REPO_ROOT"
  PYTHONPATH="$REPO_ROOT:${PYTHONPATH:-}" \
    nohup "$PY" -m wannavegtour.line_listener \
      --host "$LISTEN_HOST" --port "$LISTEN_PORT" \
      >> "$LIST_LOG_FILE" 2>&1 &
  LIST_PID=$!
  echo "$LIST_PID" > "$LIST_PID_FILE"
  echo "[listener] started pid=$LIST_PID on http://$LISTEN_HOST:$LISTEN_PORT (log: $LIST_LOG_FILE)"
  for _ in 1 2 3 4 5 6; do
    sleep 0.5
    if curl -sS -m 1 "http://$LISTEN_HOST:$LISTEN_PORT/healthz" >/dev/null 2>&1; then
      echo "[listener] /healthz responded ✓"
      break
    fi
    if ! kill -0 "$LIST_PID" 2>/dev/null; then
      echo "  ✗ listener died immediately; check $LIST_LOG_FILE" >&2
      tail -20 "$LIST_LOG_FILE" >&2 || true
      exit 1
    fi
  done
fi

# --- 2. tailscale funnel -------------------------------------------------------

echo "[tailscale funnel] configuring on port ${LISTEN_PORT}..."
if sudo tailscale funnel --bg "$LISTEN_PORT" 2>&1; then
  echo "[tailscale funnel] ✓ exposed"
else
  echo "  ⚠️  funnel command failed; check Tailscale ACL grants funnel attr to this node" >&2
  echo "     (listener stays running; re-run funnel manually after fixing ACL)" >&2
fi

TAILNET=$(tailscale status --json 2>/dev/null | "$PY" -c "import sys,json;print(json.load(sys.stdin)['Self']['DNSName'].rstrip('.'))" 2>/dev/null || echo "unknown.ts.net")
echo
echo "════════════════════════════════════════════════════════════════════"
echo "  Public webhook URL (set this in LINE Developers Console):"
echo "    https://$TAILNET/wannavegtour/line/webhook"
echo
echo "  Health check:"
echo "    https://$TAILNET/healthz"
echo
echo "  Stop:  sudo tailscale funnel reset && kill \$(cat $LIST_PID_FILE)"
echo "  Tail listener log: tail -F $LIST_LOG_FILE"
echo "════════════════════════════════════════════════════════════════════"
