#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-queue-pickup — local SEO OS autopilot queue dispatcher.

A2/A3/B1 local MVP:
- policy decision before dispatch
- guarded dispatch wrapper for pre_dispatch + post_agent_run
- failure creates workflow events / follow-up tasks through wrapper
- successful expected_output can be indexed as artifact by wrapper

Local-only helper: no deploy, no push, no direct Payload/CMS write.
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

ROOT = Path("/Users/garyyang/clients/ohya")
sys.path.insert(0, str(ROOT / "lib"))
import seo_os_db  # noqa: E402

DISPATCH_HELPER = ROOT / "bin" / "seo-dispatch-with-guardrail"
POLICY_HELPER = ROOT / "bin" / "seo-policy-decision"


def fetch_pending_tasks(limit: int, task_id: str | None = None) -> list[dict]:
    rows = seo_os_db.query_json(
        """
        SELECT
          t.id, t.type, t.status, t.priority, t.slug, t.payload_post_id,
          t.assigned_agent, t.input_summary,
          CASE
            WHEN approved_gate.id IS NULL THEN t.metadata
            ELSE t.metadata || jsonb_build_object(
              'approval_id', approved_gate.id::text,
              'approval_action', approved_gate.action
            )
          END AS metadata,
          t.created_at
        FROM seo_os.tasks t
        LEFT JOIN LATERAL (
          SELECT a.id, a.action
          FROM seo_os.approvals a
          WHERE a.task_id = t.id
            AND a.status = 'approved'
            AND a.action IN ('create_cms_draft', 'published_content_correction')
          ORDER BY a.decided_at DESC NULLS LAST, a.created_at DESC
          LIMIT 1
        ) approved_gate ON t.type = 'cms_draft'
        WHERE t.status = 'pending'
          AND t.assigned_agent IS NOT NULL
          AND (%s::uuid IS NULL OR t.id = %s::uuid)
        ORDER BY
          CASE t.priority
            WHEN 'urgent' THEN 0 WHEN 'high' THEN 1
            WHEN 'medium' THEN 2 WHEN 'low' THEN 3 ELSE 4
          END,
          t.created_at ASC
        LIMIT %s
        """,
        [task_id, task_id, limit],
    )
    return rows


def claim_task(task_id) -> bool:
    rows = seo_os_db.query_json(
        """
        UPDATE seo_os.tasks
        SET status = 'running', updated_at = now()
        WHERE id = %s AND status = 'pending'
        RETURNING id
        """,
        [task_id],
    )
    return bool(rows)


def build_prompt_for_task(task: dict) -> str:
    slug = task.get("slug")
    task_type = task.get("type")
    summary = task.get("input_summary", "")
    metadata = task.get("metadata") if isinstance(task.get("metadata"), dict) else {}
    common_footer = (
        f"\n\n# Task tracking\n"
        f"task_id: {task['id']}\n"
        f"type: {task_type}\n"
        f"slug: {slug}\n"
        f"完成後請輸出明確 artifact path，並避免 production write / publish / deploy / git push / Zeabur env / secret 輸出。"
    )
    if task_type == "refresh":
        return f"對 slug=`{slug}` 跑舊文 audit + 修改方案，產 audit-report.md + patch-plan.json + fix-queue.json artifact。summary: {summary}{common_footer}"
    if task_type == "audit":
        return f"對 slug=`{slug}` 跑舊文 audit，產 audit-report 與 patch-plan。{common_footer}"
    if task_type == "internal_link_fix":
        return f"對 slug=`{slug}` 找內部相關文章建議內鏈插入位置，產 link-suggestions.json artifact。{common_footer}"
    if task_type == "cannibalization_scan":
        return f"對 slug=`{slug}` 掃 keyword cannibalization，產 cannibalization-report.json。{common_footer}"
    if task_type == "cms_draft":
        patch_path = metadata.get("patch_plan_path", "(see metadata.patch_plan_artifact_id)")
        post_id = task.get("payload_post_id") or metadata.get("approved_payload_post_id")
        approval_id = metadata.get("approval_id")
        approval_action = metadata.get("approval_action")
        if not approval_id:
            return f"BLOCKER: cms_draft lacks approval_id. Do not write Payload. slug=`{slug}`.{common_footer}"
        if post_id:
            return f"從 patch_plan {patch_path} 更新 Payload draft（post id={post_id}, slug=`{slug}`, approval_id={approval_id}）。禁止 publish/deploy/migration/direct SQL。{common_footer}"
        if approval_action == "create_cms_draft":
            return f"從 patch_plan {patch_path} 建立新的 Payload draft（slug=`{slug}`, approval_id={approval_id}）。只允許 _status=draft；禁止 publish/deploy/migration/direct SQL。{common_footer}"
        return f"BLOCKER: cms_draft lacks post_id and is not an approved create_cms_draft action. Do not write Payload. slug=`{slug}`.{common_footer}"
    return f"處理 task type={task_type} slug={slug}。{summary}{common_footer}"


def policy_action_for_task(task: dict) -> tuple[str, str, bool, bool]:
    task_type = task.get("type")
    metadata = task.get("metadata") if isinstance(task.get("metadata"), dict) else {}
    if task_type == "publish":
        return "publish", "high", True, True
    if task_type == "cms_draft":
        if metadata.get("approval_action") == "create_cms_draft" and metadata.get("approval_id"):
            return "create_cms_draft", "high", True, False
        return "update_article", "medium", False, False
    if metadata.get("production_write") is True:
        return str(metadata.get("action") or task_type), "high", True, True
    if task_type in {"refresh", "audit", "pre_publish_audit", "research", "outline", "write", "link_fix", "internal_link_fix", "query", "cannibalization_scan"}:
        return str(task_type), "low", False, False
    return str(task_type), "unknown", False, False


def run_policy_decision(task: dict, *, persist_db: bool) -> dict:
    action, risk, production_write, destructive = policy_action_for_task(task)
    cmd = [
        str(POLICY_HELPER), "decide",
        "--task-id", str(task["id"]),
        "--task-type", str(task.get("type")),
        "--action", action,
        "--risk-level", risk,
        "--actor", "seo-queue-pickup",
        "--json",
    ]
    if task.get("slug"):
        cmd += ["--slug", str(task.get("slug"))]
    if task.get("payload_post_id"):
        cmd += ["--post-id", str(task.get("payload_post_id"))]
    metadata = task.get("metadata") if isinstance(task.get("metadata"), dict) else {}
    if metadata.get("approval_id"):
        cmd += ["--approval-id", str(metadata.get("approval_id")), "--approved"]
    if production_write:
        cmd.append("--production-write")
    if destructive:
        cmd.append("--destructive")
    if persist_db:
        cmd.append("--persist-db")
    cp = subprocess.run(cmd, cwd=str(ROOT), text=True, capture_output=True, timeout=60)
    try:
        data = json.loads(cp.stdout)
    except Exception:
        data = {"ok": False, "parse_error": True, "stdout_preview": cp.stdout[:1000], "stderr_preview": cp.stderr[:1000]}
    data["process_exit_code"] = cp.returncode
    return data


def create_policy_followup(task: dict, policy: dict) -> dict:
    decision = policy.get("decision")
    if decision == "destructive_requires_approval":
        status = "awaiting_approval"
        event_type = "approval_requested"
        message = "policy requires Gary approval before destructive/prod action"
    else:
        status = "failed"
        event_type = "next_task_created"
        message = "policy exception generated review task"
    seo_os_db.query_json(
        "UPDATE seo_os.tasks SET status=%s, updated_at=now(), metadata = COALESCE(metadata, '{}'::jsonb) || %s::jsonb WHERE id=%s RETURNING id",
        [status, json.dumps({"policy_block": policy}, ensure_ascii=False, default=str), task["id"]],
    )
    review = None
    if decision != "destructive_requires_approval":
        rows = seo_os_db.query_json(
            """
            INSERT INTO seo_os.tasks (source, type, status, priority, slug, payload_post_id, assigned_agent, parent_task_id, input_summary, metadata)
            VALUES ('system', 'query', 'pending', 'medium', %s, %s, 'seo-graph', %s, %s, %s::jsonb)
            RETURNING id, type, status, assigned_agent, parent_task_id
            """,
            [task.get("slug"), task.get("payload_post_id"), task["id"], "Review policy exception before autopilot continues.", json.dumps({"generated_by": "seo-queue-pickup", "policy": policy}, ensure_ascii=False, default=str)],
        )
        review = rows[0] if rows else None
    ev = seo_os_db.record_workflow_event(
        task_id=task["id"],
        event_type=event_type,
        actor_type="system",
        actor_id="seo-queue-pickup",
        message=message,
        metadata={"policy": policy, "review_task": review},
    )
    return {"ok": True, "task_status": status, "event_id": str(ev.get("id")) if ev.get("id") else None, "review_task": review, "secret_redacted": True}


def run_guarded_dispatch(task: dict, args, *, dry_run: bool) -> dict:
    prompt = build_prompt_for_task(task)
    cmd = [
        str(DISPATCH_HELPER),
        "--profile", str(task["assigned_agent"]),
        "--task-type", str(task["type"]),
        "--task-id", str(task["id"]),
        "--prompt", prompt,
        "--source-text", str(task.get("input_summary") or ""),
        "--timeout", str(args.timeout),
    ]
    if task.get("slug"):
        cmd += ["--slug", str(task.get("slug"))]
    if task.get("payload_post_id"):
        cmd += ["--post-id", str(task.get("payload_post_id"))]
    if args.expected_output:
        cmd += ["--expected-output", args.expected_output]
    if args.artifact_manifest:
        cmd += ["--artifact-manifest", args.artifact_manifest]
    if args.artifact_type:
        cmd += ["--artifact-type", args.artifact_type]
    if args.test_command:
        cmd += ["--test-command", args.test_command]
    if dry_run:
        cmd.append("--dry-run")
    else:
        cmd.append("--persist-db")
    cp = subprocess.run(cmd, cwd=str(ROOT), text=True, capture_output=True, timeout=args.timeout + 180)
    try:
        data = json.loads(cp.stdout)
    except Exception:
        data = {"ok": False, "parse_error": True, "stdout_preview": cp.stdout[:2000], "stderr_preview": cp.stderr[:2000]}
    data["process_exit_code"] = cp.returncode
    return data


def dispatch_one(task: dict, args) -> dict:
    dry_run = args.dry_run
    policy = run_policy_decision(task, persist_db=not dry_run)
    policy_summary = {
        "ok": policy.get("ok"),
        "decision": policy.get("decision"),
        "next_allowed": policy.get("next_allowed"),
        "requires_gary_approval": policy.get("requires_gary_approval"),
        "recommended_next_action": policy.get("recommended_next_action"),
    }
    if not policy.get("next_allowed"):
        followup = None if dry_run else create_policy_followup(task, policy)
        return {"task_id": str(task["id"]), "agent": task.get("assigned_agent"), "claimed": False, "blocked_by_policy": True, "policy": policy_summary, "policy_followup": followup, "prompt_preview": build_prompt_for_task(task)[:200] if dry_run else None}
    if dry_run:
        dispatch = run_guarded_dispatch(task, args, dry_run=True)
        return {"task_id": str(task["id"]), "agent": task.get("assigned_agent"), "dry_run": True, "policy": policy_summary, "dispatch": dispatch, "prompt_preview": build_prompt_for_task(task)[:200]}
    if not claim_task(task["id"]):
        return {"task_id": str(task["id"]), "claimed": False, "reason": "already not pending (raced or already dispatched)", "policy": policy_summary}
    seo_os_db.record_workflow_event(
        task_id=task["id"],
        event_type="agent_dispatched",
        actor_type="system",
        actor_id="seo-queue-pickup",
        message=f"dispatching {task['assigned_agent']} with guarded wrapper",
        metadata={"agent": task["assigned_agent"], "task_type": task["type"], "policy": policy_summary},
    )
    dispatch = run_guarded_dispatch(task, args, dry_run=False)
    return {"task_id": str(task["id"]), "agent": task.get("assigned_agent"), "task_type": task.get("type"), "slug": task.get("slug"), "claimed": True, "policy": policy_summary, "dispatch": dispatch, "ok": dispatch.get("ok") is True}


def cmd_list(args):
    rows = fetch_pending_tasks(args.limit, args.task_id)
    print(json.dumps({
        "ok": True,
        "pending_count": len(rows),
        "tasks": [{"id": str(r["id"]), "type": r["type"], "priority": r["priority"], "slug": r.get("slug"), "agent": r.get("assigned_agent"), "payload_post_id": r.get("payload_post_id"), "summary": r.get("input_summary"), "created_at": r.get("created_at")} for r in rows],
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def cmd_dispatch(args):
    try:
        rows = fetch_pending_tasks(args.limit, args.task_id)
    except Exception as e:
        print(json.dumps({"ok": False, "dispatched_count": 0, "error_type": type(e).__name__, "error": "DB unavailable while fetching pending tasks", "detail": str(e)[:300], "secret_redacted": True}, ensure_ascii=False, indent=2, default=str))
        sys.exit(0)
    results = []
    for r in rows:
        try:
            results.append(dispatch_one(r, args))
        except Exception as e:
            results.append({"task_id": str(r["id"]), "ok": False, "error_type": type(e).__name__, "error": str(e), "secret_redacted": True})
    print(json.dumps({"ok": all(x.get("ok", True) is not False for x in results), "dispatched_count": sum(1 for x in results if x.get("claimed")), "results": results, "secret_redacted": True}, ensure_ascii=False, indent=2, default=str))


def cmd_status(args):
    rows = seo_os_db.query_json(
        """
        SELECT t.id, t.type, t.status, t.priority, t.slug, t.assigned_agent, t.created_at, t.updated_at,
               (SELECT count(*) FROM seo_os.artifacts a WHERE a.task_id = t.id) AS artifact_count,
               (SELECT count(*) FROM seo_os.workflow_events e WHERE e.task_id = t.id) AS event_count
        FROM seo_os.tasks t
        WHERE t.id = %s
        """,
        [args.task_id],
    )
    if not rows:
        print(json.dumps({"ok": False, "error": "task not found"}, ensure_ascii=False))
        sys.exit(1)
    print(json.dumps({"ok": True, "task": rows[0], "secret_redacted": True}, ensure_ascii=False, indent=2, default=str))


def main():
    p = argparse.ArgumentParser()
    sp = p.add_subparsers(dest="cmd", required=True)

    ls = sp.add_parser("list")
    ls.add_argument("--limit", type=int, default=20)
    ls.add_argument("--task-id")
    ls.set_defaults(func=cmd_list)

    dp = sp.add_parser("dispatch")
    dp.add_argument("--limit", type=int, default=5)
    dp.add_argument("--task-id")
    dp.add_argument("--dry-run", action="store_true")
    dp.add_argument("--test-command", help="local verification only: command passed to guarded dispatch")
    dp.add_argument("--expected-output", help="local verification or known artifact path for post_agent_run")
    dp.add_argument("--artifact-manifest", help="optional JSON manifest with artifacts list")
    dp.add_argument("--artifact-type", default="other")
    dp.add_argument("--timeout", type=int, default=600)
    dp.set_defaults(func=cmd_dispatch)

    st = sp.add_parser("status")
    st.add_argument("task_id")
    st.set_defaults(func=cmd_status)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
