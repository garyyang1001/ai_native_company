#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-lifecycle-sync — 把 Neo4j Article node 同步進 PostgreSQL seo_os.article_lifecycle.

Usage:
  seo-lifecycle-sync [--dry-run] [--limit N]

Only syncs Article nodes that have scraped_at (i.e. real published articles, not smoke-test stubs).
Idempotent — uses ON CONFLICT (slug) DO UPDATE.

Safety:
  - Read-only against Neo4j.
  - Write to local seo_os.article_lifecycle only.
  - Never prints DB URI / credentials.
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

ROOT = Path("/Users/garyyang/clients/ohya")
sys.path.insert(0, str(ROOT / "lib"))
import seo_os_db  # noqa: E402

NEO4J_QUERY = ROOT / "bin" / "neo4j-query"


def fetch_neo4j_articles(limit: int) -> list[dict]:
    cypher = (
        "MATCH (a:Article) "
        "WHERE a.scraped_at IS NOT NULL "
        "RETURN a.slug AS slug, a.title AS title, a.url AS url, "
        "a.scraped_at AS scraped_at, a.payload_post_id AS payload_post_id "
        f"ORDER BY a.scraped_at DESC LIMIT {limit}"
    )
    out = subprocess.check_output([str(NEO4J_QUERY), cypher], text=True)
    def clean(v: str) -> str | None:
        v = v.strip().strip('"')
        if v in ("NULL", "null", ""):
            return None
        return v

    rows = []
    for ln in out.strip().splitlines()[1:]:
        parts = [p.strip() for p in ln.split(", ", 4)]
        if len(parts) < 5:
            continue
        slug = clean(parts[0])
        if not slug:
            continue
        rows.append({
            "slug": slug,
            "title": clean(parts[1]),
            "url": clean(parts[2]),
            "scraped_at": clean(parts[3]),
            "payload_post_id": clean(parts[4]),
        })
    return rows


def upsert_lifecycle(rows: list[dict], dry_run: bool) -> dict:
    if dry_run:
        return {"dry_run": True, "would_upsert": len(rows), "sample": rows[:3]}

    upserted = 0
    for r in rows:
        # 不把 scraped_at 寫進 last_publish_at（那是 Neo4j 抓進系統的時間，不是真實 publish date）。
        # 只把 scraped_at 留在 metadata 供追蹤。實際 publish date 要從 Payload CMS 或 sitemap 取得。
        seo_os_db.execute(
            """
            INSERT INTO seo_os.article_lifecycle
                (slug, url, payload_post_id, state, metadata)
            VALUES (%s, %s, %s, 'published',
                    jsonb_build_object(
                        'title', %s::text,
                        'sync_source', 'neo4j',
                        'neo4j_scraped_at', %s::text,
                        'sync_at', now()::text
                    ))
            ON CONFLICT (slug) DO UPDATE SET
                url = COALESCE(EXCLUDED.url, seo_os.article_lifecycle.url),
                payload_post_id = COALESCE(EXCLUDED.payload_post_id, seo_os.article_lifecycle.payload_post_id),
                metadata = seo_os.article_lifecycle.metadata || EXCLUDED.metadata,
                updated_at = now()
            """,
            [r["slug"], r["url"], r["payload_post_id"], r["title"], r["scraped_at"]],
        )
        upserted += 1
    return {"dry_run": False, "upserted": upserted}


def main():
    p = argparse.ArgumentParser()
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("--limit", type=int, default=200)
    args = p.parse_args()

    rows = fetch_neo4j_articles(args.limit)
    result = upsert_lifecycle(rows, args.dry_run)
    print(json.dumps({
        "ok": True,
        "neo4j_articles_fetched": len(rows),
        "result": result,
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


if __name__ == "__main__":
    main()
