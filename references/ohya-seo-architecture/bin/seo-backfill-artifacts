#!/usr/bin/env python3
from __future__ import annotations

import argparse, hashlib, json, mimetypes, re, sys
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path('/Users/garyyang/clients/ohya')
WORKSPACE = Path('/Users/garyyang/workspace/ohya')
sys.path.insert(0, str(ROOT / 'lib'))
import seo_os_db  # noqa

SCAN_DIRS = {
    'audits': WORKSPACE / 'audits',
    'priority-scans': WORKSPACE / 'priority-scans',
    'cannibalization': WORKSPACE / 'cannibalization',
    'evolution-reports': WORKSPACE / 'evolution-reports',
    'fact-check': WORKSPACE / 'fact-check',
}

ARTIFACT_TYPE_BY_DIR = {
    'audits': 'audit_report',
    'priority-scans': 'performance_report',
    'cannibalization': 'performance_report',
    'evolution-reports': 'performance_report',
    'fact-check': 'performance_report',
}

ARTIFACT_TYPE_BY_NAME = {
    'audit-report.md': 'audit_report',
    'patch-plan.json': 'patch_plan',
    'fix-queue.json': 'fix_queue',
    'gsc-raw.json': 'gsc_raw',
    'priority-report.md': 'performance_report',
    'priority-queue.json': 'performance_report',
    'cannibalization-report.md': 'performance_report',
    'cannibalization-data.json': 'performance_report',
    'fact-check-report.md': 'performance_report',
}

IGNORE_NAMES = {'.DS_Store', '.rotation-state'}


def out(data, code=0):
    print(json.dumps(data, ensure_ascii=False, indent=2, default=str)); return code


def sha256_file(path: Path) -> str:
    h=hashlib.sha256()
    with path.open('rb') as f:
        for chunk in iter(lambda:f.read(1024*1024), b''):
            h.update(chunk)
    return h.hexdigest()


def infer_slug(path: Path) -> str | None:
    parts = path.relative_to(WORKSPACE).parts
    text = '/'.join(parts)
    # audits/2026-04-16-slug/audit-report.md -> slug
    for part in parts:
        m = re.match(r'^\d{4}-\d{2}-\d{2}-(.+)$', part)
        if m:
            return m.group(1)
    # filename with date prefix
    m = re.match(r'^\d{4}-\d{2}-\d{2}-(.+?)\.(md|json|txt)$', path.name)
    if m:
        return m.group(1)
    # avoid treating broad report filenames as slugs
    if any(key in text for key in ['evolution-reports', 'priority-scans', 'cannibalization', 'fact-check']):
        return None
    return None


def classify(path: Path, root_key: str) -> str:
    return ARTIFACT_TYPE_BY_NAME.get(path.name, ARTIFACT_TYPE_BY_DIR.get(root_key, 'other'))


def scan_files(since: str | None = None, with_hash: bool = True):
    since_dt = None
    if since:
        since_dt = datetime.fromisoformat(since).replace(tzinfo=timezone.utc) if 'T' in since else datetime.fromisoformat(since + 'T00:00:00+00:00')
    items=[]
    for root_key, root in SCAN_DIRS.items():
        if not root.exists():
            continue
        for p in sorted(root.rglob('*')):
            if not p.is_file() or p.name in IGNORE_NAMES:
                continue
            stat=p.stat()
            mtime=datetime.fromtimestamp(stat.st_mtime, timezone.utc)
            if since_dt and mtime < since_dt:
                continue
            mime=mimetypes.guess_type(str(p))[0] or 'application/octet-stream'
            item={
                'path': str(p),
                'type': classify(p, root_key),
                'slug': infer_slug(p),
                'root': root_key,
                'size_bytes': stat.st_size,
                'mtime': mtime.isoformat(),
                'mime_type': mime,
                'sha256': sha256_file(p) if with_hash else None,
            }
            items.append(item)
    return items


def cmd_scan(args):
    items=scan_files(args.since, with_hash=not args.no_hash)
    by_root={}
    by_type={}
    for i in items:
        by_root[i['root']]=by_root.get(i['root'],0)+1
        by_type[i['type']]=by_type.get(i['type'],0)+1
    return out({'ok': True, 'dry_run': args.dry_run, 'count': len(items), 'by_root': by_root, 'by_type': by_type, 'items': items[:args.limit], 'truncated': len(items)>args.limit, 'secret_redacted': True})


def cmd_import(args):
    items=scan_files(args.since, with_hash=True)
    if args.dry_run:
        return out({'ok': True, 'dry_run': True, 'would_import': len(items), 'items': items[:args.limit], 'truncated': len(items)>args.limit, 'secret_redacted': True})
    seo_os_db.assert_not_production_unless_allowed()
    imported=[]; skipped=[]
    for i in items:
        exists=seo_os_db.query_json('SELECT id FROM seo_os.artifacts WHERE path=%s OR sha256=%s LIMIT 1', [i['path'], i['sha256']])
        if exists:
            skipped.append({'path': i['path'], 'reason': 'already_exists', 'id': exists[0]['id']})
            continue
        row=seo_os_db.query_json(
            """
            INSERT INTO seo_os.artifacts (type, path, slug, agent, summary, status, sha256, mime_type, size_bytes, metadata)
            VALUES (%s,%s,%s,'system',%s,'active',%s,%s,%s,%s::jsonb)
            RETURNING id, type, path, slug, created_at
            """,
            [i['type'], i['path'], i['slug'], f"Backfilled from {i['root']}", i['sha256'], i['mime_type'], i['size_bytes'], json.dumps({'backfill': True, 'root': i['root'], 'mtime': i['mtime']})]
        )[0]
        imported.append(row)
    return out({'ok': True, 'dry_run': False, 'imported_count': len(imported), 'skipped_count': len(skipped), 'imported': imported[:args.limit], 'skipped': skipped[:args.limit], 'secret_redacted': True})


def build():
    p=argparse.ArgumentParser(description='Backfill existing SEO workspace artifacts into seo_os.artifacts')
    sub=p.add_subparsers(dest='cmd', required=True)
    s=sub.add_parser('scan'); s.add_argument('--dry-run', action='store_true'); s.add_argument('--since'); s.add_argument('--limit', type=int, default=50); s.add_argument('--no-hash', action='store_true'); s.set_defaults(func=cmd_scan)
    i=sub.add_parser('import'); i.add_argument('--dry-run', action='store_true'); i.add_argument('--since'); i.add_argument('--limit', type=int, default=50); i.set_defaults(func=cmd_import)
    return p

if __name__ == '__main__':
    a=build().parse_args(); raise SystemExit(a.func(a))
