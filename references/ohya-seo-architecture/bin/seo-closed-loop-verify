#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-closed-loop-verify — Component-level E2E health check.

Closed-loop spec ref: §12 (Definition of Done)

跑一輪每個 component 的 health check，確認：
1. helper 程式都跑得起來
2. cron job 都註冊
3. DB schema 對齊
4. Neo4j constraints 在
5. credentials 路徑存在（不讀內容）
6. coordinator skill 檔案存在

不執行 production write、不 spawn sub-agent、不送 Telegram。
"""
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

ROOT = Path("/Users/garyyang/clients/ohya")
sys.path.insert(0, str(ROOT / "lib"))
import seo_os_db  # noqa: E402

results = {"checks": [], "ok": True}


def check(name: str, fn):
    try:
        ok, info = fn()
    except Exception as e:
        ok, info = False, f"exception: {e}"
    results["checks"].append({"name": name, "ok": ok, "info": info})
    if not ok:
        results["ok"] = False


# ---- helpers ----
HELPERS = [
    "seo-performance-snapshot", "seo-performance-compare", "seo-next-task-rule",
    "seo-performance-effect-check", "seo-approval-relay", "seo-queue-pickup",
    "seo-cms-draft-dispatch", "seo-lifecycle-sync", "seo-db", "seo-os-query",
    "content-priority", "neo4j-query", "md-to-gdoc", "gsc-query",
]
for h in HELPERS:
    p = ROOT / "bin" / h
    check(f"helper exists: {h}", lambda p=p: (p.exists() and p.stat().st_mode & 0o111 != 0, str(p)))

# ---- helper smoke test (--help) ----
PYTHON_HELPERS = [
    "seo-performance-snapshot", "seo-performance-compare", "seo-next-task-rule",
    "seo-performance-effect-check", "seo-approval-relay", "seo-queue-pickup",
    "seo-cms-draft-dispatch", "seo-lifecycle-sync",
]
for h in PYTHON_HELPERS:
    p = ROOT / "bin" / h
    def _run_help(p=p):
        r = subprocess.run([str(p), "--help"], capture_output=True, text=True, timeout=10)
        return (r.returncode == 0, f"exit={r.returncode}, stdout_len={len(r.stdout)}")
    check(f"--help works: {h}", _run_help)

# ---- DB ----
def _check_db():
    rows = seo_os_db.query_json(
        "SELECT current_database() AS db, current_user AS u",
    )
    return (bool(rows) and rows[0]["db"] == "ohya_seo_os_local",
            f"db={rows[0]['db']}, user={rows[0]['u']}")
check("PostgreSQL ohya_seo_os_local connected", _check_db)

def _check_tables():
    rows = seo_os_db.query_json(
        "SELECT table_name FROM information_schema.tables WHERE table_schema='seo_os' ORDER BY 1"
    )
    expected = {"agent_runs", "approvals", "article_lifecycle", "artifacts",
                "decisions", "performance_snapshots", "tasks", "weekly_reports",
                "workflow_events"}
    found = {r["table_name"] for r in rows}
    missing = expected - found
    return (not missing, f"found {len(found)} tables, missing: {missing or 'none'}")
check("PostgreSQL seo_os schema has 9 tables", _check_tables)

def _check_constraints():
    rows = seo_os_db.query_json("""
        SELECT count(*) AS n FROM pg_constraint c
        JOIN pg_namespace n ON c.connamespace = n.oid
        WHERE n.nspname='seo_os' AND contype='c'
    """)
    n = rows[0]["n"]
    return (n >= 20, f"{n} CHECK constraints")
check("PostgreSQL CHECK constraints (003-006 applied)", _check_constraints)

# ---- Article lifecycle synced ----
def _check_lifecycle():
    rows = seo_os_db.query_json("SELECT count(*) AS n FROM seo_os.article_lifecycle")
    n = rows[0]["n"]
    return (n >= 100, f"{n} articles in lifecycle")
check("article_lifecycle sync >= 100 rows", _check_lifecycle)

# ---- performance_snapshots ----
def _check_snapshots():
    rows = seo_os_db.query_json(
        "SELECT count(DISTINCT slug) AS slugs FROM seo_os.performance_snapshots WHERE source='gsc'"
    )
    n = rows[0]["slugs"]
    return (n >= 100, f"{n} unique slugs in performance_snapshots")
check("performance_snapshots first batch ran", _check_snapshots)

# ---- Neo4j ----
def _check_neo4j():
    r = subprocess.run([str(ROOT / "bin" / "neo4j-query"),
                        "SHOW CONSTRAINTS YIELD name RETURN count(*) AS n"],
                       capture_output=True, text=True, timeout=10)
    out = r.stdout
    if "5" not in out:
        return (False, f"output: {out[:200]}")
    return (True, "5 constraints")
check("Neo4j constraints (5 unique)", _check_neo4j)

# ---- Credentials ----
import os
for c in ["~/.credentials/payload-admin.env", "~/.credentials/gsc-token.json"]:
    p = Path(os.path.expanduser(c))
    check(f"credential exists: {c}", lambda p=p: (p.exists(), f"size={p.stat().st_size if p.exists() else 0}"))

# ---- Coordinator SOUL hard rule ----
soul = (ROOT / "profiles/coordinator/SOUL.md").read_text() if (ROOT / "profiles/coordinator/SOUL.md").exists() else ""
check("coordinator SOUL has hard routing rule",
      lambda: ("Hard routing rule" in soul, f"soul_len={len(soul)}"))

# ---- Skills ----
SKILLS = [
    "profiles/coordinator/skills/content/seo-approval-handler/SKILL.md",
    "profiles/coordinator/skills/content/seo-queue-pickup/SKILL.md",
]
for s in SKILLS:
    p = ROOT / s
    check(f"skill exists: {s}", lambda p=p: (p.exists(), str(p)))

# ---- Cron jobs ----
def _check_cron():
    r = subprocess.run([
        "/Users/garyyang/.hermes/hermes-agent/venv/bin/python",
        "-m", "hermes_cli.main", "cron", "list"
    ], capture_output=True, text=True, timeout=10,
       env={**os.environ, "HERMES_HOME": str(ROOT / "profiles/coordinator")})
    expected_jobs = ["ohya-gsc-daily-snapshot", "ohya-weekly-next-task-plan",
                     "ohya-performance-effect-check", "ohya-cms-draft-dispatch"]
    found = [j for j in expected_jobs if j in r.stdout]
    return (len(found) == 4, f"found {len(found)}/4: {found}")
check("Hermes cron jobs registered (4)", _check_cron)

# ---- Final ----
print(json.dumps(results, ensure_ascii=False, indent=2))
sys.exit(0 if results["ok"] else 1)
