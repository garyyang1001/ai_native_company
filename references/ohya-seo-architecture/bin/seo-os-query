#!/usr/bin/env python3
from __future__ import annotations

import argparse, json, sys
from pathlib import Path

ROOT = Path('/Users/garyyang/clients/ohya')
sys.path.insert(0, str(ROOT / 'lib'))
import seo_os_db  # noqa


def out(data, code=0): print(json.dumps(data, ensure_ascii=False, indent=2, default=str)); return code

def recent_tasks(args):
    rows=seo_os_db.query_json(
        """
        SELECT id, created_at, status, priority, type, slug, assigned_agent, input_summary, failure_reason
        FROM seo_os.tasks
        WHERE created_at >= now() - (%s::text || ' days')::interval
        ORDER BY created_at DESC
        LIMIT %s
        """, [args.days, args.limit])
    return out({'ok': True, 'query': 'recent-tasks', 'count': len(rows), 'tasks': rows, 'secret_redacted': True})

def failed_runs(args):
    rows=seo_os_db.query_json(
        """
        SELECT ar.id, ar.task_id, ar.agent, ar.profile, ar.started_at, ar.ended_at, ar.exit_code, ar.duration_seconds, ar.error_message, t.slug, t.type AS task_type
        FROM seo_os.agent_runs ar
        LEFT JOIN seo_os.tasks t ON t.id = ar.task_id
        WHERE ar.status IN ('failed','timeout','cancelled')
          AND ar.started_at >= now() - (%s::text || ' days')::interval
        ORDER BY ar.started_at DESC
        LIMIT %s
        """, [args.days, args.limit])
    return out({'ok': True, 'query': 'failed-runs', 'count': len(rows), 'runs': rows, 'secret_redacted': True})

def pending_approvals(args):
    rows=seo_os_db.query_json(
        """
        SELECT id, task_id, created_at, action, risk_level, requested_by, required_approver_type, required_approver_id, approval_message, metadata
        FROM seo_os.approvals
        WHERE status='pending'
        ORDER BY created_at DESC
        LIMIT %s
        """, [args.limit])
    return out({'ok': True, 'query': 'pending-approvals', 'count': len(rows), 'approvals': rows, 'secret_redacted': True})

def artifacts(args):
    rows=seo_os_db.query_json(
        """
        SELECT id, created_at, type, path, google_doc_url, slug, agent, summary, status, size_bytes
        FROM seo_os.artifacts
        WHERE (%s::text IS NULL OR slug=%s)
        ORDER BY created_at DESC
        LIMIT %s
        """, [args.slug,args.slug,args.limit])
    return out({'ok': True, 'query': 'artifacts', 'count': len(rows), 'artifacts': rows, 'secret_redacted': True})

def build():
    p=argparse.ArgumentParser(description='SEO OS query helper')
    sub=p.add_subparsers(dest='cmd', required=True)
    r=sub.add_parser('recent-tasks'); r.add_argument('--days', type=int, default=7); r.add_argument('--limit', type=int, default=20); r.set_defaults(func=recent_tasks)
    f=sub.add_parser('failed-runs'); f.add_argument('--days', type=int, default=14); f.add_argument('--limit', type=int, default=20); f.set_defaults(func=failed_runs)
    a=sub.add_parser('pending-approvals'); a.add_argument('--limit', type=int, default=20); a.set_defaults(func=pending_approvals)
    ar=sub.add_parser('artifacts'); ar.add_argument('--slug'); ar.add_argument('--limit', type=int, default=20); ar.set_defaults(func=artifacts)
    return p

if __name__ == '__main__':
    a=build().parse_args(); raise SystemExit(a.func(a))
