#!/usr/bin/env python3
"""Read an ohya.co article by URL and return clean plain text.
Usage: get-article "https://ohya.co/blog/xxx/"
       get-article "https://ohya.co/blog/..." --chars 1000
       get-article "https://ohya.co/blog/..." --raw   (return raw HTML)

Source: Payload CMS REST API at https://ohya.co/api/posts
"""
import sys, json, re, html, subprocess
from urllib.parse import urlparse


def slug_from_url(url):
    """Extract slug from ohya.co URL."""
    path = urlparse(url).path.strip("/")
    parts = path.split("/")
    # /blog/slug or just /slug
    return parts[-1] if parts else ""


def from_payload_api(slug):
    """Fetch article from Payload CMS REST API."""
    if not slug:
        return None, None
    api_url = f"https://ohya.co/api/posts?where[slug][equals]={slug}&limit=1"
    result = subprocess.run(
        ["curl", "-s", "-g", "--max-time", "20", api_url],
        capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        return None, None
    try:
        data = json.loads(result.stdout)
        docs = data.get("docs", [])
        if docs:
            post = docs[0]
            title = post.get("title", "")
            content_html = post.get("content_html", "")
            return title, content_html
    except json.JSONDecodeError:
        pass
    return None, None


def html_to_text(content_html):
    text = re.sub(r'<!--.*?-->', '', content_html, flags=re.S)
    text = re.sub(r'<script[^>]*>.*?</script>', '', text, flags=re.S | re.I)
    text = re.sub(r'<style[^>]*>.*?</style>', '', text, flags=re.S | re.I)
    text = re.sub(r'<[^>]+>', '\n', text)
    text = html.unescape(text)
    text = re.sub(r'\n\s*\n', '\n', text)
    text = re.sub(r'[ \t]+', ' ', text)
    return text.strip()


def main():
    if len(sys.argv) < 2:
        print("Usage: get-article <url> [--chars N] [--raw]", file=sys.stderr)
        sys.exit(1)
    url = sys.argv[1]
    chars = 2000
    raw_mode = "--raw" in sys.argv
    if "--chars" in sys.argv:
        idx = sys.argv.index("--chars")
        chars = int(sys.argv[idx + 1])

    slug = slug_from_url(url)
    title, content_html = from_payload_api(slug)

    if not content_html:
        print(f"Not found: {url} (Payload API returned nothing)", file=sys.stderr)
        sys.exit(1)

    if raw_mode:
        print(content_html)
        return

    text = html_to_text(content_html)

    print(f"# {title}\n")
    print(f"URL: {url}")
    print(f"Source: payload-api\n")
    print(text[:chars])
    if len(text) > chars:
        print(f"\n... (文章共 {len(text)} 字，已截取前 {chars} 字)")


if __name__ == "__main__":
    main()
