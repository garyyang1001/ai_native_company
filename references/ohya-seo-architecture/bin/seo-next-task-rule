#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-next-task-rule — 根據 performance bucket 自動產 next task.

Usage:
  seo-next-task-rule plan [--limit N] [--dry-run]
  seo-next-task-rule create [--limit N]              # 真的 INSERT seo_os.tasks

Bucket → action mapping:
  decaying      → article-editor refresh (audit + patch_plan)
  stale         → article-editor refresh
  almost_there  → article-editor refresh + link-finder boost
  zombie        → manual review (decisions.scope='content_opportunity')
  unranked      → cannibalization scan
  healthy       → no action
  new           → no action（still ramping）
  needs_review  → decisions.scope='workflow' (Gary 看)

Tasks created have parent_task_id pointing to a virtual seo-performance-feedback-loop task.
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from datetime import datetime

ROOT = Path('/Users/garyyang/clients/ohya')
sys.path.insert(0, str(ROOT / 'lib'))
import seo_os_db  # noqa: E402

# bucket → (task_type, assigned_agent, priority, action_summary)
BUCKET_RULES = {
    "decaying":     ("refresh",                 "article-editor", "high",   "Performance decaying — audit + fix queue"),
    "stale":        ("refresh",                 "article-editor", "medium", "High impressions, zero clicks — review CTR / title / meta"),
    "almost_there": ("internal_link_fix",       "link-finder",    "high",   "Position 11-20 — boost via internal links"),
    "zombie":       ("audit",                   "article-editor", "low",    "No impressions — strategic review needed"),
    "unranked":     ("cannibalization_scan",    "article-editor", "medium", "High position, low impressions — possible cannibalization"),
    "healthy":      (None, None, None, None),
    "new":          (None, None, None, None),
    "needs_review": ("audit",                   "article-editor", "medium", "Performance pattern unclear — manual review"),
}


def latest_snapshots(period: int = 90):
    return seo_os_db.query_json(
        """
        SELECT DISTINCT ON (slug) slug, url, bucket, priority_score, clicks, impressions, avg_position, period_days
        FROM seo_os.performance_snapshots
        WHERE period_days=%s
        ORDER BY slug, snapshot_date DESC
        """,
        [period],
    )


def existing_open_task_for_slug(slug: str, task_type: str) -> bool:
    rows = seo_os_db.query_json(
        """
        SELECT id FROM seo_os.tasks
        WHERE slug=%s AND type=%s AND status IN ('pending','running','awaiting_approval')
        LIMIT 1
        """,
        [slug, task_type],
    )
    return bool(rows)


def recent_effect_history(slug: str, days: int = 90) -> list[dict]:
    """看過去 N 天 effect-check 對這個 slug 的結果。

    Closed-loop spec ref: §3.2 (priority-decay logic v2)

    Returns list of recent verdicts: 'improved' / 'unchanged' / 'worsened'.
    """
    rows = seo_os_db.query_json(
        """
        SELECT created_at,
               metadata->>'verdict' AS verdict,
               metadata->'deltas' AS deltas
        FROM seo_os.workflow_events
        WHERE event_type = 'performance_checked'
          AND metadata->>'slug' = %s
          AND created_at >= now() - (%s::text || ' days')::interval
        ORDER BY created_at DESC
        """,
        [slug, days],
    )
    return rows


def apply_priority_decay(plan_entry: dict) -> dict:
    """v2 priority-decay：基於 effect-history 調整 plan_entry。

    - 過去 90 天有 ≥ 1 次 'worsened' 或 'unchanged' → 降 priority、改 task type
    - 過去 90 天有 ≥ 2 次任何 effect-check → 強制 cannibalization_scan（避免重複派 refresh）
    - 過去 90 天 'improved' → 不動（讓它跑）
    - 沒任何歷史 → 不動
    """
    history = recent_effect_history(plan_entry["slug"], days=90)
    if not history:
        return plan_entry

    verdicts = [h.get("verdict") for h in history]
    plan_entry["effect_history_count"] = len(history)
    plan_entry["effect_history_verdicts"] = verdicts

    worsened_or_unchanged = [v for v in verdicts if v in ("worsened", "unchanged")]
    if len(verdicts) >= 2:
        # 已被改過 ≥ 2 次，避免反覆 refresh：改派 cannibalization scan
        plan_entry["proposed_task_type"] = "cannibalization_scan"
        plan_entry["proposed_agent"] = "article-editor"
        plan_entry["proposed_priority"] = "medium"
        plan_entry["decay_action"] = "switched_to_cannibalization_scan (refresh tried >= 2 times)"
        plan_entry["summary"] = (
            f"曾跑 {len(verdicts)} 次 refresh-style fix，"
            f"verdicts={verdicts}，改派 cannibalization scan 找根因"
        )
    elif worsened_or_unchanged:
        # 一次沒效，降 priority 不換 type
        if plan_entry["proposed_priority"] == "high":
            plan_entry["proposed_priority"] = "medium"
        elif plan_entry["proposed_priority"] == "medium":
            plan_entry["proposed_priority"] = "low"
        plan_entry["decay_action"] = (
            f"priority demoted (last refresh verdict: {worsened_or_unchanged[0]})"
        )
    return plan_entry


def plan_next_tasks(bucket_filter: str | None = None, top: int | None = None, period: int = 90):
    """Build plan from latest snapshots.

    bucket_filter: only consider this bucket (None = all eligible buckets).
    top: after sorting by priority_score DESC, take top N (None = all).
    period: performance_snapshots.period_days to use (default 90 for Phase 2.0A).
    """
    snapshots = latest_snapshots(period=period)
    if bucket_filter:
        snapshots = [s for s in snapshots if s.get("bucket") == bucket_filter]
    snapshots.sort(key=lambda r: -(r.get("priority_score") or 0))

    plan = []
    for s in snapshots:
        bucket = s.get("bucket")
        rule = BUCKET_RULES.get(bucket)
        if not rule or rule[0] is None:
            continue
        task_type, agent, priority, summary = rule
        entry = {
            "slug": s["slug"], "url": s.get("url"), "bucket": bucket,
            "priority_score": s.get("priority_score"),
            "proposed_task_type": task_type, "proposed_agent": agent, "proposed_priority": priority,
            "summary": summary,
            "metrics_28d": {
                "clicks": s.get("clicks"), "impressions": s.get("impressions"),
                "avg_position": s.get("avg_position"),
            },
        }
        # v2: apply priority-decay based on effect history before checking open-task collision
        entry = apply_priority_decay(entry)
        skip = existing_open_task_for_slug(s["slug"], entry["proposed_task_type"])
        entry["skip_reason"] = "open task already exists" if skip else None
        entry["would_create"] = not skip
        plan.append(entry)

    if top is not None:
        # only count would_create rows toward the top-N cap; skipped ones don't consume the budget
        capped = []
        creatable = 0
        for p in plan:
            if p["would_create"]:
                if creatable >= top:
                    break
                creatable += 1
            capped.append(p)
        plan = capped
    return plan


def cmd_plan(args):
    plan = plan_next_tasks(bucket_filter=args.bucket, top=args.top, period=args.period)
    print(json.dumps({
        "ok": True, "dry_run": True,
        "filter": {"bucket": args.bucket, "top": args.top, "period_days": args.period},
        "plan_count": len(plan),
        "would_create": sum(1 for p in plan if p["would_create"]),
        "would_skip":   sum(1 for p in plan if not p["would_create"]),
        "plan": plan, "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def cmd_create(args):
    plan = plan_next_tasks(bucket_filter=args.bucket, top=args.top, period=args.period)
    created = []
    skipped = []
    for p in plan:
        if not p["would_create"]:
            skipped.append({"slug": p["slug"], "reason": p["skip_reason"]})
            continue
        rows = seo_os_db.query_json(
            """
            INSERT INTO seo_os.tasks
                (source, type, status, priority, slug, assigned_agent, input_summary, metadata)
            VALUES ('priority_scan', %s, 'pending', %s, %s, %s, %s, %s::jsonb)
            RETURNING id
            """,
            [
                p["proposed_task_type"], p["proposed_priority"], p["slug"], p["proposed_agent"],
                p["summary"],
                json.dumps({"source_bucket": p["bucket"], "priority_score": p["priority_score"], "phase": "2.0"}),
            ],
        )
        task_id = rows[0]["id"]
        seo_os_db.execute(
            """
            INSERT INTO seo_os.workflow_events (task_id, event_type, actor_type, actor_id, message, metadata)
            VALUES (%s, 'next_task_created', 'system', 'seo-next-task-rule', %s, %s::jsonb)
            """,
            [task_id, f"Created from feedback loop: bucket={p['bucket']}, agent={p['proposed_agent']}",
             json.dumps({"slug": p["slug"], "bucket": p["bucket"]})],
        )
        created.append({"task_id": str(task_id), "slug": p["slug"], "type": p["proposed_task_type"], "agent": p["proposed_agent"]})

    print(json.dumps({
        "ok": True, "created_count": len(created), "skipped_count": len(skipped),
        "created": created, "skipped": skipped, "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


VALID_BUCKETS = ["decaying", "stale", "almost_there", "zombie", "unranked", "needs_review"]


def main():
    p = argparse.ArgumentParser(
        description="Build / create next tasks from performance_snapshots.\n"
                    "Examples:\n"
                    "  seo-next-task-rule plan                              # all eligible\n"
                    "  seo-next-task-rule plan --bucket decaying --top 5    # 5 most-decaying\n"
                    "  seo-next-task-rule create --top 10                   # create top 10 by priority\n"
                    "  seo-next-task-rule create --bucket almost_there --top 3",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sp = p.add_subparsers(dest="cmd", required=True)

    for sub_name, fn in (("plan", cmd_plan), ("create", cmd_create)):
        sub = sp.add_parser(sub_name)
        sub.add_argument("--bucket", choices=VALID_BUCKETS,
                         help="只考慮此 bucket（不指定 = 全部 eligible bucket）")
        sub.add_argument("--top", type=int,
                         help="按 priority_score DESC 取前 N 個 would_create（不指定 = 全部）")
        sub.add_argument("--period", type=int, default=90,
                         help="使用哪個 performance_snapshots.period_days（預設 90；Phase 2.0A 建議 90/180 搭配 weekly report）")
        sub.set_defaults(func=fn)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
