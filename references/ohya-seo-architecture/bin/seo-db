#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-db: safety and verification CLI for Ohya SEO Growth OS."""
from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

ROOT = Path('/Users/garyyang/clients/ohya')
LIB = ROOT / 'lib'
sys.path.insert(0, str(LIB))

import seo_os_db  # noqa: E402


def print_json(data, code: int = 0):
    print(json.dumps(data, ensure_ascii=False, indent=2, default=str))
    return code


def cmd_check(args):
    status = seo_os_db.redacted_config_status()
    if not status['configured']:
        status['ok'] = False
        status['message'] = 'DB connection not configured. Set SEO_OS_DATABASE_URI or DATABASE_URI. Secret redacted.'
        return print_json(status, 2)
    try:
        rows = seo_os_db.query_json('SELECT current_database() AS database, current_user AS user, version() AS version')
        row = rows[0] if rows else {}
        status.update({
            'ok': True,
            'database': row.get('database'),
            'user': row.get('user'),
            'version_preview': (row.get('version') or '')[:80],
            'secret_redacted': True,
        })
        return print_json(status)
    except Exception as e:
        status.update({'ok': False, 'error_type': type(e).__name__, 'error': str(e), 'secret_redacted': True})
        return print_json(status, 1)


def cmd_tables(args):
    status = seo_os_db.redacted_config_status()
    if not status['configured']:
        return print_json({'ok': False, 'message': 'DB connection not configured; cannot list tables.', 'secret_redacted': True}, 2)
    try:
        tables = seo_os_db.table_names()
        return print_json({'ok': True, 'schema': 'seo_os', 'tables': tables, 'count': len(tables), 'secret_redacted': True})
    except Exception as e:
        return print_json({'ok': False, 'error_type': type(e).__name__, 'error': str(e), 'secret_redacted': True}, 1)


def cmd_rollback_plan(args):
    migrations = [str(p) for p in seo_os_db.migration_files()]
    plan = {
        'ok': True,
        'automatic_rollback': False,
        'production_safe': True,
        'secret_redacted': True,
        'migrations': migrations,
        'policy': [
            '正式 production migration 必須先經 Gary approval。',
            '本工具不自動 drop schema / delete data。',
            'rollback 以 restore backup 或手動 SQL review 為主。',
            '若 migration 尚未套用，rollback = 不執行 migrate。',
        ],
        'manual_steps': [
            '1. 確認 migration 前備份：pg_dump --schema=seo_os 或完整 DB snapshot。',
            '2. 若只在 local/staging 測試，優先直接重建測試 DB。',
            '3. 若 production 已套用且需回復，先停止寫入，再由人工審核 drop/alter SQL。',
            '4. 所有 destructive SQL 必須進 approval queue，不由 seo-db 自動執行。',
        ],
    }
    return print_json(plan)


def cmd_migrate(args):
    files = seo_os_db.migration_files()
    validation = seo_os_db.validate_sql_files(files)
    if args.dry_run:
        return print_json({
            'ok': all(v['ok'] for v in validation),
            'dry_run': True,
            'will_execute': False,
            'secret_redacted': True,
            'files': validation,
            'message': 'Dry-run only: SQL files parsed; no DB writes executed.',
        }, 0 if all(v['ok'] for v in validation) else 1)
    return print_json({
        'ok': False,
        'blocked': True,
        'message': 'Real migration is intentionally blocked in Phase 1. Use --dry-run only until Gary approves production/staging target.',
        'secret_redacted': True,
    }, 3)


def cmd_smoke_test(args):
    status = seo_os_db.redacted_config_status()
    if not status['configured']:
        return print_json({'ok': False, 'message': 'DB connection not configured; smoke-test skipped.', 'secret_redacted': True}, 2)
    if seo_os_db.looks_like_production_uri() and os.environ.get('SEO_OS_ALLOW_PRODUCTION_SMOKE') != 'I_UNDERSTAND':
        return print_json({'ok': False, 'blocked': True, 'message': 'Connection looks like production; smoke-test blocked without SEO_OS_ALLOW_PRODUCTION_SMOKE=I_UNDERSTAND.', 'secret_redacted': True}, 3)
    try:
        with seo_os_db.connect() as conn:
            with conn.cursor() as cur:
                cur.execute('BEGIN')
                cur.execute("""
                    INSERT INTO seo_os.tasks (source, type, status, priority, slug, assigned_agent, input_summary, metadata)
                    VALUES ('system', 'query', 'running', 'low', 'smoke-test', 'system', 'seo-db smoke test', '{"smoke": true}'::jsonb)
                    RETURNING id
                """)
                task_id = cur.fetchone()['id']
                cur.execute("""
                    INSERT INTO seo_os.agent_runs (task_id, agent, profile, status, input_prompt, metadata)
                    VALUES (%s, 'system', 'seo-db', 'running', 'smoke test', '{"smoke": true}'::jsonb)
                    RETURNING id
                """, (task_id,))
                run_id = cur.fetchone()['id']
                cur.execute("""
                    INSERT INTO seo_os.artifacts (task_id, agent_run_id, type, path, slug, agent, summary, metadata)
                    VALUES (%s, %s, 'other', '/tmp/seo-db-smoke-test.txt', 'smoke-test', 'system', 'smoke artifact', '{"smoke": true}'::jsonb)
                    RETURNING id
                """, (task_id, run_id))
                artifact_id = cur.fetchone()['id']
                cur.execute("""
                    INSERT INTO seo_os.workflow_events (task_id, agent_run_id, event_type, actor_type, actor_id, message, metadata)
                    VALUES (%s, %s, 'task_created', 'system', 'seo-db', 'smoke event', '{"smoke": true}'::jsonb)
                    RETURNING id
                """, (task_id, run_id))
                event_id = cur.fetchone()['id']
                cur.execute('SELECT count(*) AS c FROM seo_os.workflow_events WHERE task_id = %s', (task_id,))
                event_count = cur.fetchone()['c']
                cur.execute('ROLLBACK')
        return print_json({
            'ok': True,
            'rolled_back': True,
            'inserted': {'task_id': str(task_id), 'agent_run_id': str(run_id), 'artifact_id': str(artifact_id), 'event_id': str(event_id), 'event_count': event_count},
            'message': 'Smoke-test insert/select succeeded and transaction was rolled back.',
            'secret_redacted': True,
        })
    except Exception as e:
        return print_json({'ok': False, 'error_type': type(e).__name__, 'error': str(e), 'secret_redacted': True}, 1)


def build_parser():
    p = argparse.ArgumentParser(description='Ohya SEO Growth OS DB safety CLI')
    sub = p.add_subparsers(dest='cmd', required=True)
    sub.add_parser('check', help='Check DB connection without printing secrets').set_defaults(func=cmd_check)
    sub.add_parser('tables', help='List seo_os tables').set_defaults(func=cmd_tables)
    sub.add_parser('rollback-plan', help='Print manual rollback plan; no destructive actions').set_defaults(func=cmd_rollback_plan)
    m = sub.add_parser('migrate', help='Validate migration plan; real migration blocked in Phase 1')
    m.add_argument('--dry-run', action='store_true', help='Parse SQL files without executing')
    m.set_defaults(func=cmd_migrate)
    sub.add_parser('smoke-test', help='Insert/select in a transaction and rollback').set_defaults(func=cmd_smoke_test)
    return p


def main(argv=None):
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == '__main__':
    raise SystemExit(main())
