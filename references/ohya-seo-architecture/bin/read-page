#!/usr/bin/env python3
"""Fetch a URL and return clean text.
Usage: read-page "https://example.com/article"

For ohya.co URLs: uses Payload CMS API (bypass any CDN issues).
For external URLs: uses curl directly.
"""
import sys, re, html, subprocess, json
from urllib.parse import urlparse

url = sys.argv[1] if len(sys.argv) > 1 else ""
if not url:
    print("Usage: read-page <url>", file=sys.stderr)
    sys.exit(1)


def fetch_ohya(url):
    """Fetch ohya.co via Payload CMS API."""
    path = urlparse(url).path.strip("/")
    slug = path.split("/")[-1] if path else ""
    if not slug:
        return None
    api_url = f"https://ohya.co/api/posts?where[slug][equals]={slug}&limit=1"
    result = subprocess.run(
        ["curl", "-s", "-g", "--max-time", "20", api_url],
        capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        return None
    try:
        data = json.loads(result.stdout)
        docs = data.get("docs", [])
        if docs:
            return docs[0].get("content_html", "")
    except json.JSONDecodeError:
        pass
    return None


def fetch_external(url):
    """Fetch external URL via curl."""
    result = subprocess.run(
        [
            "curl", "-sL", "--max-time", "20",
            "-A", "Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0",
            "-H", "Accept: text/html,application/xhtml+xml",
            "-H", "Accept-Language: zh-TW,zh;q=0.9,en;q=0.8",
            url,
        ],
        capture_output=True, text=True, timeout=30,
    )
    if result.returncode != 0:
        return None
    return result.stdout


# Decide source
if "ohya.co" in url:
    raw = fetch_ohya(url)
    if not raw:
        raw = fetch_external(url)
else:
    raw = fetch_external(url)

if not raw:
    print(f"Error fetching {url}", file=sys.stderr)
    sys.exit(1)

# Strip to text
text = re.sub(r'<script[^>]*>.*?</script>', '', raw, flags=re.S | re.I)
text = re.sub(r'<style[^>]*>.*?</style>', '', text, flags=re.S | re.I)
text = re.sub(r'<!--.*?-->', '', text, flags=re.S)
text = re.sub(r'<[^>]+>', '\n', text)
text = html.unescape(text)
text = re.sub(r'\n\s*\n', '\n', text)
text = re.sub(r'[ \t]+', ' ', text)
print(text.strip()[:8000])
