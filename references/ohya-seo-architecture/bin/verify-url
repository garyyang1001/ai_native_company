#!/usr/bin/env bash
# Verify a URL is alive via HEAD check.
# Usage: verify-url "https://example.com/path"
# Returns: JSON { "url": "...", "final_url": "...", "status": 200, "alive": true }
set -u

URL="${1:-}"
if [ -z "$URL" ]; then
  echo '{"error": "URL required"}'
  exit 2
fi

RESULT=$(curl -sI -L --max-redirs 5 --max-time 10 \
  -H "User-Agent: Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0" \
  -o /dev/null -w '%{http_code}|%{url_effective}' "$URL" 2>/dev/null)

STATUS="${RESULT%%|*}"
FINAL_URL="${RESULT#*|}"

case "$STATUS" in
  200|301|302|303|307|308)
    ALIVE=true
    EXIT=0
    ;;
  *)
    ALIVE=false
    EXIT=1
    ;;
esac

printf '{"url": "%s", "final_url": "%s", "status": %s, "alive": %s}\n' \
  "$URL" "$FINAL_URL" "$STATUS" "$ALIVE"
exit $EXIT
