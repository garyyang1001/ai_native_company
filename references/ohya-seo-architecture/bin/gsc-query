#!/usr/bin/env python3.11
"""
gsc-query — 查 Google Search Console 數據 (28 + 90 天)

Usage:
  gsc-query <url>                    產出 search-console.json (28 + 90 天)
  gsc-query <url> --period 28d       只要 28 天
  gsc-query <url> --period 90d       只要 90 天
  gsc-query <url> --raw              整包原始 rows,不聚合
  gsc-query --auth                   初次 OAuth 授權 (會開瀏覽器)
  gsc-query --site                   列出 gary 帳號可存取的 site 清單

Requires:
  - ~/clients/ohya/credentials/gsc-credentials.json (OAuth client)
  - ~/.credentials/gsc-token.json (首次 --auth 後自動產生)
  - google-api-python-client + google-auth-oauthlib
"""

import sys, os, json, argparse
from datetime import date, timedelta
from urllib.parse import urlparse

try:
    from google.oauth2.credentials import Credentials
    from google_auth_oauthlib.flow import InstalledAppFlow
    from google.auth.transport.requests import Request
    from googleapiclient.discovery import build
    from googleapiclient.errors import HttpError
except ImportError:
    print("ERROR: missing deps. run: python3.11 -m pip install google-api-python-client google-auth-oauthlib", file=sys.stderr)
    sys.exit(1)

SCOPES = [
    "https://www.googleapis.com/auth/webmasters.readonly",
    "https://www.googleapis.com/auth/drive.file",
]
def first_existing_path(*candidates):
    """Resolve credentials even when Hermes profile changes HOME."""
    expanded = [os.path.expanduser(p) for p in candidates]
    for p in expanded:
        if os.path.exists(p):
            return p
    return expanded[0]


CLIENT_SECRET = first_existing_path(
    "~/clients/ohya/credentials/gsc-credentials.json",
    "/Users/garyyang/clients/ohya/credentials/gsc-credentials.json",
)
TOKEN_FILE = first_existing_path(
    "~/.credentials/gsc-token.json",
    "/Users/garyyang/.credentials/gsc-token.json",
)

SITE_URL = "https://ohya.co/"


def get_credentials(interactive=False):
    creds = None
    if os.path.exists(TOKEN_FILE):
        try:
            creds = Credentials.from_authorized_user_file(TOKEN_FILE, SCOPES)
        except Exception as e:
            print(f"WARN: cannot load token: {e}", file=sys.stderr)
            creds = None

    if creds and creds.valid:
        return creds
    if creds and creds.expired and creds.refresh_token:
        try:
            creds.refresh(Request())
            os.makedirs(os.path.dirname(TOKEN_FILE), exist_ok=True)
            with open(TOKEN_FILE, "w") as f:
                f.write(creds.to_json())
            os.chmod(TOKEN_FILE, 0o600)
            return creds
        except Exception as e:
            print(f"WARN: refresh failed: {e}", file=sys.stderr)

    if not interactive:
        print("ERROR: no valid credentials. run: gsc-query --auth", file=sys.stderr)
        sys.exit(2)

    if not os.path.exists(CLIENT_SECRET):
        print(f"ERROR: {CLIENT_SECRET} not found", file=sys.stderr)
        sys.exit(3)
    flow = InstalledAppFlow.from_client_secrets_file(CLIENT_SECRET, SCOPES)
    creds = flow.run_local_server(port=0, open_browser=True, prompt="consent")
    os.makedirs(os.path.dirname(TOKEN_FILE), exist_ok=True)
    with open(TOKEN_FILE, "w") as f:
        f.write(creds.to_json())
    os.chmod(TOKEN_FILE, 0o600)
    print(f"✅ credentials saved to {TOKEN_FILE}", file=sys.stderr)
    return creds


def build_service():
    creds = get_credentials(interactive=False)
    return build("webmasters", "v3", credentials=creds, cache_discovery=False)


def list_sites():
    service = build_service()
    resp = service.sites().list().execute()
    return resp.get("siteEntry", [])


def query_for_period(service, site_url, page_url, days):
    end = date.today()
    start = end - timedelta(days=days)
    body = {
        "startDate": start.isoformat(),
        "endDate": end.isoformat(),
        "dimensions": ["query"],
        "dimensionFilterGroups": [
            {"filters": [{"dimension": "page", "operator": "equals", "expression": page_url}]}
        ],
        "rowLimit": 50,
        "orderBy": [{"field": "clicks", "descending": True}],
    }
    try:
        resp = service.searchanalytics().query(siteUrl=site_url, body=body).execute()
    except HttpError as e:
        print(f"ERROR: GSC API {e.resp.status}: {e}", file=sys.stderr)
        sys.exit(4)

    rows = resp.get("rows", [])
    impressions = sum(r["impressions"] for r in rows)
    clicks = sum(r["clicks"] for r in rows)
    ctr = clicks / impressions if impressions > 0 else 0.0
    if impressions > 0:
        avg_position = sum(r["position"] * r["impressions"] for r in rows) / impressions
    else:
        avg_position = 0.0

    top_keywords = [
        {
            "query": r["keys"][0],
            "impressions": r["impressions"],
            "clicks": r["clicks"],
            "ctr": round(r["ctr"], 4),
            "position": round(r["position"], 2),
        }
        for r in rows[:50]
    ]
    return {
        "period": f"{days}d",
        "date_range": {"start": start.isoformat(), "end": end.isoformat()},
        "impressions": impressions,
        "clicks": clicks,
        "ctr": round(ctr, 4),
        "avg_position": round(avg_position, 2),
        "top_keywords": top_keywords,
    }


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("url", nargs="?")
    ap.add_argument("--period", choices=["28d", "90d", "both"], default="both")
    ap.add_argument("--raw", action="store_true", help="print unaggregated rows")
    ap.add_argument("--auth", action="store_true", help="Run OAuth flow (opens browser)")
    ap.add_argument("--site", action="store_true", help="List available sites")
    ap.add_argument("--site-url", default=SITE_URL, help=f"Site URL (default: {SITE_URL})")
    args = ap.parse_args()

    if args.auth:
        get_credentials(interactive=True)
        return

    if args.site:
        sites = list_sites()
        for s in sites:
            print(f"{s.get('permissionLevel', '?'):20} {s.get('siteUrl', '?')}")
        return

    if not args.url:
        ap.error("url required (or use --auth / --site)")

    service = build_service()

    result = {
        "url": args.url,
        "site_url": args.site_url,
        "fetched_at": date.today().isoformat(),
    }

    periods_to_run = [28] if args.period == "28d" else [90] if args.period == "90d" else [28, 90]
    for days in periods_to_run:
        result[f"period_{days}d"] = query_for_period(service, args.site_url, args.url, days)

    print(json.dumps(result, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
