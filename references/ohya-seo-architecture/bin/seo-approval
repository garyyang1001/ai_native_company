#!/usr/bin/env python3
from __future__ import annotations

import argparse, json, sys
from pathlib import Path

ROOT = Path('/Users/garyyang/clients/ohya')
sys.path.insert(0, str(ROOT / 'lib'))
import seo_os_db  # noqa


def out(data, code=0):
    print(json.dumps(data, ensure_ascii=False, indent=2, default=str)); return code


def cmd_request(args):
    seo_os_db.assert_not_production_unless_allowed()
    row = seo_os_db.query_json(
        """
        INSERT INTO seo_os.approvals (task_id, action, risk_level, requested_by, required_approver_type, required_approver_id, status, approval_message, metadata)
        VALUES (%s,%s,%s,%s,%s,%s,'pending',%s,%s::jsonb)
        RETURNING id, task_id, action, risk_level, requested_by, required_approver_type, required_approver_id, status, approval_message, created_at
        """,
        [args.task_id, args.action, args.risk_level, args.requested_by, args.required_approver_type, args.required_approver_id, args.message, args.metadata],
    )[0]
    return out({'ok': True, 'approval': row, 'secret_redacted': True})


def cmd_list(args):
    rows = seo_os_db.query_json(
        """
        SELECT id, task_id, decision_id, action, risk_level, requested_by, required_approver_type, required_approver_id, status, approval_message, created_at, decided_at, metadata
        FROM seo_os.approvals
        WHERE (%s::text IS NULL OR status = %s)
          AND (%s::uuid IS NULL OR task_id = %s::uuid)
        ORDER BY created_at DESC
        LIMIT %s
        """,
        [args.status, args.status, args.task_id, args.task_id, args.limit],
    )
    return out({'ok': True, 'count': len(rows), 'approvals': rows, 'secret_redacted': True})


def cmd_decide(args):
    seo_os_db.assert_not_production_unless_allowed()
    row = seo_os_db.query_json(
        """
        UPDATE seo_os.approvals
        SET status=%s, decided_at=now(), decision_id=COALESCE(%s::uuid, decision_id), approval_message=COALESCE(%s, approval_message), metadata=metadata || %s::jsonb
        WHERE id=%s
        RETURNING id, task_id, decision_id, action, risk_level, status, approval_message, created_at, decided_at
        """,
        [args.status, args.decision_id, args.message, args.metadata, args.id],
    )
    return out({'ok': bool(row), 'approval': row[0] if row else None, 'secret_redacted': True}, 0 if row else 1)


def build():
    p = argparse.ArgumentParser(description='SEO OS approval helper')
    sub = p.add_subparsers(dest='cmd', required=True)
    r = sub.add_parser('request')
    r.add_argument('--task-id')
    r.add_argument('--action', required=True)
    r.add_argument('--risk-level', default='low')
    r.add_argument('--requested-by', default='coordinator')
    r.add_argument('--required-approver-type', default='gary')
    r.add_argument('--required-approver-id')
    r.add_argument('--message')
    r.add_argument('--metadata', default='{}')
    r.set_defaults(func=cmd_request)
    l = sub.add_parser('list')
    l.add_argument('--status')
    l.add_argument('--task-id')
    l.add_argument('--limit', type=int, default=20)
    l.set_defaults(func=cmd_list)
    d = sub.add_parser('decide')
    d.add_argument('id')
    d.add_argument('--status', required=True, choices=['approved','rejected','expired','cancelled'])
    d.add_argument('--message')
    d.add_argument('--decision-id')
    d.add_argument('--metadata', default='{}')
    d.set_defaults(func=cmd_decide)
    return p


if __name__ == '__main__':
    a = build().parse_args(); raise SystemExit(a.func(a))
