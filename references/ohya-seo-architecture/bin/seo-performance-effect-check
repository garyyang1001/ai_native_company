#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-performance-effect-check — 比對 refresh 前後成效有無改善.

Closed-loop spec ref: §3.2 + §11 (effect check)

對所有「refresh task 完成 ≥ 28 天」的文章，重抓 GSC 資料跟「refresh 前的 baseline snapshot」比對：
  - clicks_delta / impressions_delta / position_delta
  - 是否有改善（improved / unchanged / worsened）
  - 寫進 seo_os.workflow_events type=performance_checked

Usage:
  seo-performance-effect-check check                # 跑 default 規則：refresh ≥ 28d 前完成
  seo-performance-effect-check check --slug SLUG   # 強制 check 指定 slug
  seo-performance-effect-check report               # 看歷史 effect-check 結果摘要

Safety:
  - Read-only against GSC.
  - Read seo_os.tasks / artifacts / performance_snapshots / workflow_events
  - Write workflow_events (event_type=performance_checked) + performance_snapshots (period=28)
  - 不寫 task / artifact / approval；不 production write
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

ROOT = Path("/Users/garyyang/clients/ohya")
sys.path.insert(0, str(ROOT / "lib"))
import seo_os_db  # noqa: E402

SNAPSHOT_HELPER = ROOT / "bin" / "seo-performance-snapshot"


def find_refresh_completed_articles(min_days_since_done: int = 28) -> list[dict]:
    """找 type=refresh AND status=done AND completed >= min_days_since_done 天前的文章."""
    cutoff = datetime.now(timezone.utc) - timedelta(days=min_days_since_done)
    rows = seo_os_db.query_json(
        """
        SELECT t.id AS task_id, t.slug, t.updated_at, t.metadata
        FROM seo_os.tasks t
        WHERE t.type IN ('refresh', 'audit')
          AND t.status = 'done'
          AND t.updated_at IS NOT NULL
          AND t.updated_at <= %s::timestamptz
        ORDER BY t.updated_at DESC
        """,
        [cutoff],
    )
    # exclude slugs already checked in last 28 days
    out = []
    for r in rows:
        recent_check = seo_os_db.query_json(
            """
            SELECT created_at FROM seo_os.workflow_events
            WHERE event_type = 'performance_checked'
              AND task_id = %s
              AND created_at >= now() - interval '28 days'
            LIMIT 1
            """,
            [r["task_id"]],
        )
        if not recent_check:
            out.append(r)
    return out


def get_baseline_snapshot(slug: str, before_date: datetime) -> dict | None:
    """拿『refresh 完成日之前最近一筆 28d snapshot』當 baseline."""
    rows = seo_os_db.query_json(
        """
        SELECT clicks, impressions, ctr, avg_position, snapshot_date
        FROM seo_os.performance_snapshots
        WHERE slug = %s AND period_days = 28 AND source = 'gsc'
          AND snapshot_date < %s::date
        ORDER BY snapshot_date DESC LIMIT 1
        """,
        [slug, before_date],
    )
    return rows[0] if rows else None


def get_latest_snapshot(slug: str) -> dict | None:
    rows = seo_os_db.query_json(
        """
        SELECT clicks, impressions, ctr, avg_position, snapshot_date
        FROM seo_os.performance_snapshots
        WHERE slug = %s AND period_days = 28 AND source = 'gsc'
        ORDER BY snapshot_date DESC LIMIT 1
        """,
        [slug],
    )
    return rows[0] if rows else None


def trigger_fresh_snapshot(slug: str) -> bool:
    """Run seo-performance-snapshot one --slug 確保有最新一筆."""
    result = subprocess.run(
        [str(SNAPSHOT_HELPER), "one", slug],
        capture_output=True, text=True, timeout=60,
    )
    return result.returncode == 0


def classify_effect(baseline: dict, after: dict) -> tuple[str, dict]:
    """Compare baseline vs after; return (verdict, deltas)."""
    b_clicks = baseline.get("clicks") or 0
    a_clicks = after.get("clicks") or 0
    b_imp = baseline.get("impressions") or 0
    a_imp = after.get("impressions") or 0
    b_pos = float(baseline.get("avg_position") or 0)
    a_pos = float(after.get("avg_position") or 0)

    deltas = {
        "clicks_delta": a_clicks - b_clicks,
        "clicks_pct": ((a_clicks - b_clicks) / b_clicks * 100) if b_clicks > 0 else None,
        "impressions_delta": a_imp - b_imp,
        "impressions_pct": ((a_imp - b_imp) / b_imp * 100) if b_imp > 0 else None,
        "position_delta": round(b_pos - a_pos, 3) if b_pos > 0 and a_pos > 0 else None,  # 位置降低 = 改善
    }

    # Verdict heuristic
    score = 0
    if deltas["clicks_pct"] is not None:
        if deltas["clicks_pct"] > 20: score += 2
        elif deltas["clicks_pct"] > 5: score += 1
        elif deltas["clicks_pct"] < -20: score -= 2
        elif deltas["clicks_pct"] < -5: score -= 1
    if deltas["position_delta"] is not None:
        if deltas["position_delta"] > 1: score += 1   # 排名往上
        elif deltas["position_delta"] < -1: score -= 1
    if deltas["impressions_pct"] is not None:
        if deltas["impressions_pct"] > 20: score += 1
        elif deltas["impressions_pct"] < -20: score -= 1

    if score >= 2:
        verdict = "improved"
    elif score <= -2:
        verdict = "worsened"
    else:
        verdict = "unchanged"

    return verdict, deltas


def cmd_check(args):
    if args.slug:
        # Force check single slug
        latest = get_latest_snapshot(args.slug)
        if not latest:
            trigger_fresh_snapshot(args.slug)
            latest = get_latest_snapshot(args.slug)
        baseline = get_baseline_snapshot(args.slug, datetime.now(timezone.utc) - timedelta(days=14))
        if not baseline or not latest:
            print(json.dumps({"ok": False, "error": "missing baseline or latest snapshot"}, ensure_ascii=False))
            sys.exit(1)
        verdict, deltas = classify_effect(baseline, latest)
        print(json.dumps({
            "ok": True, "slug": args.slug, "verdict": verdict,
            "baseline": baseline, "latest": latest, "deltas": deltas,
            "secret_redacted": True,
        }, ensure_ascii=False, indent=2, default=str))
        return

    candidates = find_refresh_completed_articles(args.min_days)
    results = []
    for c in candidates:
        slug = c["slug"]
        baseline = get_baseline_snapshot(slug, c["updated_at"])
        if not baseline:
            results.append({"slug": slug, "skipped": "no baseline before refresh"})
            continue

        # Make sure we have a fresh latest snapshot
        if not args.skip_snapshot:
            trigger_fresh_snapshot(slug)
        latest = get_latest_snapshot(slug)
        if not latest:
            results.append({"slug": slug, "skipped": "no latest snapshot"})
            continue

        verdict, deltas = classify_effect(baseline, latest)

        # Write workflow_event
        seo_os_db.execute(
            """
            INSERT INTO seo_os.workflow_events
                (task_id, event_type, actor_type, actor_id, message, metadata)
            VALUES (%s, 'performance_checked', 'system', 'seo-performance-effect-check', %s, %s::jsonb)
            """,
            [
                c["task_id"], f"effect-check {slug}: {verdict}",
                json.dumps({
                    "slug": slug, "verdict": verdict, "deltas": deltas,
                    "baseline_date": str(baseline.get("snapshot_date")),
                    "latest_date": str(latest.get("snapshot_date")),
                }),
            ],
        )
        results.append({
            "slug": slug, "task_id": str(c["task_id"]),
            "verdict": verdict, "deltas": deltas,
            "baseline_date": str(baseline.get("snapshot_date")),
        })

    print(json.dumps({
        "ok": True, "checked_count": len(results),
        "improved": sum(1 for r in results if r.get("verdict") == "improved"),
        "unchanged": sum(1 for r in results if r.get("verdict") == "unchanged"),
        "worsened": sum(1 for r in results if r.get("verdict") == "worsened"),
        "results": results, "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def cmd_report(args):
    rows = seo_os_db.query_json(
        """
        SELECT created_at,
               metadata->>'slug' AS slug,
               metadata->>'verdict' AS verdict,
               metadata->'deltas' AS deltas
        FROM seo_os.workflow_events
        WHERE event_type = 'performance_checked'
        ORDER BY created_at DESC LIMIT %s
        """,
        [args.limit],
    )
    print(json.dumps({"ok": True, "count": len(rows), "history": rows, "secret_redacted": True}, ensure_ascii=False, indent=2, default=str))


def main():
    p = argparse.ArgumentParser()
    sp = p.add_subparsers(dest="cmd", required=True)

    ck = sp.add_parser("check")
    ck.add_argument("--slug", help="Force check a specific slug (ignore the 28-day filter)")
    ck.add_argument("--min-days", type=int, default=28, help="Only check articles whose refresh task completed >= N days ago")
    ck.add_argument("--skip-snapshot", action="store_true", help="Don't trigger fresh snapshot (use existing latest)")
    ck.set_defaults(func=cmd_check)

    rp = sp.add_parser("report")
    rp.add_argument("--limit", type=int, default=20)
    rp.set_defaults(func=cmd_report)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
