#!/usr/bin/env python3.11
"""
fact-checker — 找出可能引用過期官方數字的文章

策略: 用 facts-registry.json 裡的 entity 清單,交叉 Neo4j 的 MENTIONS 關係
+ 文章 updated_at 時間,找出「提到相關主題 + 超過 N 天沒更新」的文章。

如果有文章快取 (get-article),會進一步搜尋文章全文比對具體數字。

Usage:
  fact-checker                         # 全掃
  fact-checker --no-gdoc               # 跳過 Google Doc
  fact-checker --dry-run               # 只印 registry
  fact-checker --fact-id whv-417-fee   # 只查某一項
  fact-checker --stale-days 180        # 更新超過 N 天才標記 (default: 180)

Output:
  {output_dir}/fact-check-report.md
  {output_dir}/fact-check-data.json
"""

import argparse
import json
import os
import re
import subprocess
import sys
from datetime import date, datetime, timezone
from pathlib import Path

BIN_DIR = Path(__file__).resolve().parent
PROJECT_DIR = BIN_DIR.parent
REGISTRY_FILE = PROJECT_DIR / "data" / "facts-registry.json"


def load_registry(fact_id: str | None = None) -> list[dict]:
    data = json.loads(REGISTRY_FILE.read_text(encoding="utf-8"))
    facts = data["facts"]
    if fact_id:
        facts = [f for f in facts if f["id"] == fact_id]
    return facts


def find_affected_articles(fact: dict, stale_days: int) -> list[dict]:
    """Find articles that mention relevant entities AND haven't been updated recently."""
    entities = fact.get("affects_entities", [])
    if not entities:
        return []

    conditions = " OR ".join(f"e.name = '{n}'" for n in entities)
    cypher = f"""
    MATCH (a:Article)-[:MENTIONS]->(e:Entity)
    WHERE a.scraped_at IS NOT NULL
      AND ({conditions})
    WITH DISTINCT a,
         (datetime().epochMillis -
          COALESCE(a.updated_at, a.published_at, datetime('2020-01-01')).epochMillis
         ) / 86400000 AS days_since_update
    WHERE days_since_update >= {stale_days}
    RETURN a.url AS url, a.slug AS slug, a.title AS title,
           toString(a.updated_at) AS updated_at,
           toString(a.published_at) AS published_at,
           days_since_update
    ORDER BY days_since_update DESC
    """
    result = subprocess.run(
        [str(BIN_DIR / "neo4j-query"), cypher],
        capture_output=True, text=True, timeout=30,
    )

    articles = []
    header_skipped = False
    for line in result.stdout.strip().split("\n"):
        if not header_skipped:
            header_skipped = True
            continue
        if not line.strip():
            continue
        parts = _parse_csv(line)
        if len(parts) >= 6:
            articles.append({
                "url": parts[0].strip('"'),
                "slug": parts[1].strip('"'),
                "title": parts[2].strip('"'),
                "updated_at": parts[3].strip('"'),
                "published_at": parts[4].strip('"'),
                "days_since_update": int(parts[5]) if parts[5].strip().isdigit() else 0,
            })
    return articles


def try_content_check(fact: dict, article_url: str) -> list[dict] | None:
    """If article cache exists, check full text for old values."""
    result = subprocess.run(
        [str(BIN_DIR / "get-article"), article_url, "--chars", "15000"],
        capture_output=True, text=True, timeout=10,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return None  # No cache available

    text = result.stdout
    old_values = fact.get("old_values", [])
    findings = []

    for old_val in old_values:
        # Try matching the old value in text
        old_norm = old_val.replace(",", "").replace(" ", "")
        patterns = [re.escape(old_val), re.escape(old_norm)]
        num_match = re.search(r'[\d,.]+', old_val)
        if num_match:
            patterns.append(re.escape(num_match.group()))

        for pat in patterns:
            matches = list(re.finditer(pat, text, re.I))
            if matches:
                for m in matches[:1]:  # Just first match per old_val
                    start = max(0, m.start() - 40)
                    end = min(len(text), m.end() + 40)
                    context = text[start:end].replace("\n", " ").strip()
                    findings.append({
                        "old_value": old_val,
                        "context": f"...{context}...",
                    })
                break

    return findings if findings else None


def _parse_csv(line: str) -> list[str]:
    parts, current, in_quote = [], [], False
    for ch in line:
        if ch == '"':
            in_quote = not in_quote
            current.append(ch)
        elif ch == ',' and not in_quote:
            parts.append("".join(current).strip())
            current = []
        else:
            current.append(ch)
    if current:
        parts.append("".join(current).strip())
    return parts


def generate_report(all_results: list[dict]) -> str:
    total_articles = len(set(
        r["article"]["slug"] for group in all_results for r in group["articles"]
    ))

    lines = [
        "---",
        f"scan_date: {date.today().isoformat()}",
        f"facts_checked: {len(all_results)}",
        f"affected_articles: {total_articles}",
        "---",
        "",
        f"# Fact-check 報告 — {date.today().isoformat()}",
        "",
        "## 摘要",
        "",
        f"檢查 {len(all_results)} 項官方數字,",
        f"找到 **{total_articles}** 篇文章可能引用過期資訊。",
        "",
        "判斷邏輯：文章提到相關主題（簽證/工資等）+ 超過 180 天未更新。",
        "有文章快取時會進一步比對具體數字。",
        "",
        "---",
        "",
    ]

    for group in all_results:
        fact = group["fact"]
        articles = group["articles"]
        if not articles:
            continue

        lines.append(f"## {fact['name']}")
        lines.append("")
        lines.append(f"**正確值**: {fact['current_value']}（生效日: {fact.get('effective_date', '未知')}）")

        if fact.get("old_values"):
            lines.append(f"**已過期值**: {', '.join(fact['old_values'])}")
        lines.append(f"**影響文章**: {len(articles)} 篇")
        lines.append("")

        lines.append("| slug | 標題 | 距上次更新 | 確認過期? |")
        lines.append("|---|---|---|---|")

        for a in articles[:20]:  # Cap at 20 per fact
            slug = a["article"]["slug"]
            title = a["article"]["title"][:35]
            days = a["article"]["days_since_update"]

            if a.get("content_findings"):
                confirmed = "🔴 是 (" + ", ".join(f["old_value"] for f in a["content_findings"]) + ")"
            else:
                confirmed = "⚠ 需人工確認"

            lines.append(f"| `{slug}` | {title} | {days} 天 | {confirmed} |")

        lines.append("")
        lines.append("---")
        lines.append("")

    lines.append(f"_報告產出: `bin/fact-checker` · registry: `data/facts-registry.json`_")
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser(description="比對文章與官方數字登錄冊")
    parser.add_argument("--no-gdoc", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--fact-id", help="只查某一項")
    parser.add_argument("--stale-days", type=int, default=180,
                        help="文章超過 N 天沒更新才標記 (default: 180)")
    parser.add_argument("--output-dir",
                        default=os.path.expanduser("~/workspace/ohya/fact-check"))
    args = parser.parse_args()

    facts = load_registry(args.fact_id)
    print(f"載入 {len(facts)} 項官方數字", file=sys.stderr)

    if args.dry_run:
        for f in facts:
            old = ", ".join(f["old_values"]) if f["old_values"] else "(無舊值)"
            print(f"  {f['id']}: 正確={f['current_value']} | 舊值={old} | entity={f.get('affects_entities', [])}")
        return

    all_results = []

    for fact in facts:
        if not fact.get("affects_entities"):
            print(f"跳過 {fact['id']}（無 entity 關聯）", file=sys.stderr)
            continue

        print(f"檢查: {fact['name']}...", file=sys.stderr)
        articles = find_affected_articles(fact, args.stale_days)
        print(f"  找到 {len(articles)} 篇提到相關主題且 >{args.stale_days} 天沒更新", file=sys.stderr)

        enriched = []
        for a in articles:
            entry = {"article": a}
            # Try full text check if cache exists
            content_findings = try_content_check(fact, a["url"])
            if content_findings:
                entry["content_findings"] = content_findings
            enriched.append(entry)

        confirmed = sum(1 for e in enriched if e.get("content_findings"))
        if confirmed:
            print(f"  其中 {confirmed} 篇確認含過期數字", file=sys.stderr)

        all_results.append({"fact": fact, "articles": enriched})

    # Output
    out = Path(args.output_dir)
    out.mkdir(parents=True, exist_ok=True)

    has_findings = any(group["articles"] for group in all_results)

    if has_findings:
        report = generate_report(all_results)
        (out / "fact-check-report.md").write_text(report, encoding="utf-8")
        (out / "fact-check-data.json").write_text(
            json.dumps(all_results, ensure_ascii=False, indent=2, default=str),
            encoding="utf-8",
        )
        print(f"\n產出:", file=sys.stderr)
        print(f"  {out / 'fact-check-report.md'}", file=sys.stderr)

        if not args.no_gdoc:
            md_to_gdoc = BIN_DIR / "md-to-gdoc"
            if md_to_gdoc.exists():
                subprocess.run(
                    [str(md_to_gdoc), str(out / "fact-check-report.md"),
                     "--title", f"Fact-check 報告 {date.today().isoformat()}",
                     "--json"],
                    capture_output=True, text=True, timeout=30,
                )
    else:
        print("\n✅ 所有文章數字都是最新的", file=sys.stderr)

    # Summary JSON
    affected = sum(len(g["articles"]) for g in all_results)
    confirmed = sum(
        sum(1 for a in g["articles"] if a.get("content_findings"))
        for g in all_results
    )
    summary = {
        "scan_date": date.today().isoformat(),
        "facts_checked": len(facts),
        "affected_articles": affected,
        "confirmed_outdated": confirmed,
        "output_dir": str(out),
    }
    print(json.dumps(summary, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    main()
