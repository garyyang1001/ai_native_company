def capture_thumbnail(html_path: Path, png_path: Path):
    cmd = [
        "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
        "--headless", "--disable-gpu", "--window-size=1280,720", "--hide-scrollbars",
        f"--screenshot={png_path}", "--no-sandbox", f"file://{html_path}",
    ]
    subprocess.run(cmd, capture_output=True, timeout=60, check=True)


# ---------- 5. Transcript ----------
def write_transcript(brief, durations, output_dir: Path):
    def fmt(s):
        h = int(s // 3600); m = int((s % 3600) // 60); sec = s - h*3600 - m*60
        return f"{h:02d}:{m:02d}:{int(sec):02d},{int((sec%1)*1000):03d}"
    srt, txt = [], [f"# {brief['title']}", "", f"原文: {brief['source_url']}", "", "---", ""]
    cursor = 0.0
    for i, ch in enumerate(brief["chapters"], 1):
        start, end = cursor, cursor + durations[ch["id"]]
        srt += [str(i), f"{fmt(start)} --> {fmt(end)}", ch["narration"], ""]
        mm, ss = int(start // 60), int(start % 60)
        txt += [f"## [{mm:02d}:{ss:02d}] {ch['content'].get('hero', ch['content'].get('title', ch['id']))}", "", ch["narration"], ""]
        cursor = end
    (output_dir / "transcript.srt").write_text("\n".join(srt))
    (output_dir / "transcript.txt").write_text("\n".join(txt))


# ---------- 6. YouTube upload ----------
def youtube_upload(brief, mp4: Path, thumbnail: Path, srt: Path, replace_video_id: str | None = None):
    from google.oauth2.credentials import Credentials
    from googleapiclient.discovery import build
    from googleapiclient.http import MediaFileUpload
    from googleapiclient.errors import HttpError
    cred_json = json.loads(TOKEN_PATH.read_text())
    creds = Credentials(token=None, refresh_token=cred_json["refresh_token"],
        client_id=cred_json["client_id"], client_secret=cred_json["client_secret"],
        token_uri="https://oauth2.googleapis.com/token", scopes=cred_json["scopes"])
    yt = build("youtube", "v3", credentials=creds)

    if replace_video_id:
        try:
            yt.videos().delete(id=replace_video_id).execute()
            sys.stderr.write(f"  deleted old video {replace_video_id}\n")
        except HttpError as e:
            sys.stderr.write(f"  ⚠ delete failed: {e}\n")

    md = brief["youtube"]
    body = {
        "snippet": {"title": md["title"], "description": md["description"],
                    "tags": md["tags"], "categoryId": md.get("categoryId", "27"),
                    "defaultLanguage": "zh-Hant"},
        "status": {"privacyStatus": md.get("privacy", "private"), "selfDeclaredMadeForKids": False},
    }
    media = MediaFileUpload(str(mp4), chunksize=-1, resumable=True, mimetype="video/mp4")
    req = yt.videos().insert(part="snippet,status", body=body, media_body=media)
    resp = None
    while resp is None:
        _status, resp = req.next_chunk()
    vid = resp["id"]
    sys.stderr.write(f"  uploaded video_id={vid}\n")

    try:
        yt.thumbnails().set(videoId=vid, media_body=MediaFileUpload(str(thumbnail), mimetype="image/png", resumable=False)).execute()
    except HttpError as e:
        sys.stderr.write(f"  ⚠ thumbnail set failed: {e}\n")
    try:
        cap_body = {"snippet": {"videoId": vid, "language": "zh-Hant", "name": "繁體中文逐字稿", "isDraft": False}}
        yt.captions().insert(part="snippet", body=cap_body, media_body=MediaFileUpload(str(srt), mimetype="application/octet-stream", resumable=True)).execute()
    except HttpError as e:
        sys.stderr.write(f"  ⚠ caption insert failed: {e}\n")

    return {
        "video_id": vid,
        "url": f"https://youtu.be/{vid}",
        "studio_url": f"https://studio.youtube.com/video/{vid}/edit",
        "privacy": md.get("privacy", "private"),
    }


# ---------- 7. DB audit trail ----------
def write_db_audit(slug: str, post_id: int, parent_task_id: str | None, output_dir: Path,
                   mp4: Path, thumbnail: Path, srt: Path, brief_path: Path, html_path: Path,
                   metadata_path: Path, upload_record_path: Path, audio_paths: list[Path],
                   replace: bool, replaced_video_id: str | None):
    """Insert task + 8 artifacts + events for full audit trail."""
    seo_os_db.assert_not_production_unless_allowed()
    task_type = "video_replace" if replace else "video_produce"
    task = seo_os_db.query_json(
        """
        INSERT INTO seo_os.tasks (source, type, status, priority, slug, payload_post_id,
            assigned_agent, parent_task_id, input_summary, metadata)
        VALUES ('telegram', %s, 'done', 'medium', %s, %s, 'video-producer', %s, %s, %s::jsonb)
        RETURNING id
        """,
        [task_type, slug, str(post_id) if post_id else None, parent_task_id,
         f"Video {'replace' if replace else 'produce'} for {slug}",
         json.dumps({"output_dir": str(output_dir), "replaced_video_id": replaced_video_id})],
    )[0]
    task_id = task["id"]
    artifacts = [
        ("video_brief", brief_path, "Video article brief JSON"),
        ("video_composition_html", html_path, "Hyperframes composition HTML"),
        ("video_mp4", mp4, "Final rendered MP4"),
        ("video_thumbnail", thumbnail, "Thumbnail PNG"),
        ("video_metadata", metadata_path, "YouTube metadata JSON"),
        ("video_caption", srt, "Transcript SRT"),
        ("video_upload_record", upload_record_path, "YouTube upload result"),
    ]
    for atype, path, summary in artifacts:
        seo_os_db.query_json(
            """INSERT INTO seo_os.artifacts (task_id, type, path, slug, agent, summary, sha256, size_bytes)
            VALUES (%s, %s, %s, %s, 'video-producer', %s, %s, %s)""",
            [task_id, atype, str(path), slug, summary, _sha256(path), path.stat().st_size if path.exists() else 0],
        )
    for ap in audio_paths:
        seo_os_db.query_json(
            """INSERT INTO seo_os.artifacts (task_id, type, path, slug, agent, summary, sha256, size_bytes)
            VALUES (%s, 'video_audio', %s, %s, 'video-producer', %s, %s, %s)""",
            [task_id, str(ap), slug, f"Chapter narration {ap.name}", _sha256(ap), ap.stat().st_size],
        )
    events = [("video_brief_created", "Brief composed"), ("video_audio_synthesized", f"{len(audio_paths)} chapters TTS done"),
              ("video_rendered", f"MP4 {mp4.stat().st_size} bytes"), ("video_uploaded", "YouTube upload done"),
              ("task_completed", "video_produce pipeline done")]
    if replace:
        events.insert(0, ("video_replaced", f"Replaced {replaced_video_id} after Gary feedback"))
    for etype, msg in events:
        seo_os_db.query_json(
            """INSERT INTO seo_os.workflow_events (task_id, event_type, actor_type, actor_id, message)
            VALUES (%s, %s, 'agent', 'video-producer', %s)""", [task_id, etype, msg],
        )
    return task_id


def _sha256(p: Path) -> str | None:
    if not p.exists():
        return None
    import hashlib
    return hashlib.sha256(p.read_bytes()).hexdigest()


# ---------- main ----------
def cmd_produce(args):
    load_env()
    brief = json.loads(Path(args.brief).read_text())
    speed = brief.get("voice_speed", 1.25)
    output_dir = Path(args.output) if args.output else WORKSPACE_ROOT / f"{args.slug}-video"
    output_dir.mkdir(parents=True, exist_ok=True)

    sys.stderr.write(f"=== seo-video-make produce slug={args.slug} ===\n")

    # Re-use shared infra (TOOL_DIR has node_modules); copy assets/audio there + work in TOOL_DIR
    work_dir = TOOL_DIR
    audio_dir = work_dir / "assets" / "audio"
    if audio_dir.exists():
        shutil.rmtree(audio_dir)
    audio_dir.mkdir(parents=True, exist_ok=True)

    sys.stderr.write("[1/7] fish.audio TTS...\n")
    durations = synthesize_chapter_audio(brief["chapters"], audio_dir, speed)

    sys.stderr.write("[2/7] composing HTML...\n")
    html = build_composition_html(brief, durations)
    html_path = work_dir / "index.html"
    html_path.write_text(html)
    # Save canonical copy
    (output_dir / "index.html").write_text(html)

    sys.stderr.write("[3/7] hyperframes render...\n")
    if (work_dir / "renders").exists():
        for f in (work_dir / "renders").iterdir():
            if f.suffix == ".mp4":
                f.unlink()
    mp4 = render_video(html_path, work_dir)
    mp4_canonical = output_dir / "video.mp4"
    shutil.copy2(mp4, mp4_canonical)

    sys.stderr.write("[4/7] thumbnail...\n")
    thumb_html_path = work_dir / "thumbnail.html"
    thumb_html_path.write_text(build_thumbnail_html(brief))
    thumb_png = output_dir / "thumbnail.png"
    capture_thumbnail(thumb_html_path, thumb_png)

    sys.stderr.write("[5/7] transcript + metadata...\n")
    write_transcript(brief, durations, output_dir)
    metadata_path = output_dir / "metadata.json"
    metadata_path.write_text(json.dumps(brief["youtube"], ensure_ascii=False, indent=2))
    brief_path = output_dir / "brief.json"
    brief_path.write_text(Path(args.brief).read_text())

    audio_canonical = output_dir / "audio"
    if audio_canonical.exists():
        shutil.rmtree(audio_canonical)
    shutil.copytree(audio_dir, audio_canonical)
    audio_paths = sorted(audio_canonical.iterdir())

    if args.no_upload:
        upload_record = {"video_id": None, "url": None, "uploaded": False}
        upload_record_path = output_dir / "upload_result.json"
        upload_record_path.write_text(json.dumps(upload_record, ensure_ascii=False, indent=2))
        return out({"ok": True, "uploaded": False, "mp4": str(mp4_canonical),
                    "thumbnail": str(thumb_png), "output_dir": str(output_dir)})

    sys.stderr.write("[6/7] YouTube upload...\n")
    upload = youtube_upload(brief, mp4_canonical, thumb_png, output_dir / "transcript.srt",
                            replace_video_id=args.replace_video_id)
    upload_record_path = output_dir / "upload_result.json"
    upload_record_path.write_text(json.dumps(upload, ensure_ascii=False, indent=2))

    sys.stderr.write("[7/7] DB audit...\n")
    task_id = write_db_audit(args.slug, args.post_id, args.task_id, output_dir,
        mp4_canonical, thumb_png, output_dir / "transcript.srt", brief_path, output_dir / "index.html",
        metadata_path, upload_record_path, audio_paths,
        replace=bool(args.replace_video_id), replaced_video_id=args.replace_video_id)

    return out({"ok": True, "uploaded": True, "task_id": task_id,
                "video_id": upload["video_id"], "url": upload["url"],
                "studio_url": upload["studio_url"], "mp4": str(mp4_canonical),
                "thumbnail": str(thumb_png), "output_dir": str(output_dir)})


def cmd_status(args):
    rows = seo_os_db.query_json(
        """SELECT t.id, t.type, t.status, t.created_at, t.updated_at,
                  (SELECT path FROM seo_os.artifacts a WHERE a.task_id=t.id AND a.type='video_upload_record' LIMIT 1) as upload_record
           FROM seo_os.tasks t
           WHERE t.slug=%s AND t.assigned_agent='video-producer'
           ORDER BY t.created_at DESC LIMIT 5""", [args.slug])
    return out({"slug": args.slug, "videos": rows})


def cmd_publish(args):
    """Change YouTube video privacyStatus (private → public/unlisted) for slug's latest video."""
    rows = seo_os_db.query_json(
        """SELECT a.path FROM seo_os.artifacts a JOIN seo_os.tasks t ON a.task_id=t.id
           WHERE t.slug=%s AND a.type='video_upload_record'
           ORDER BY a.created_at DESC LIMIT 1""", [args.slug])
    if not rows:
        fail(f"no video upload record found for slug={args.slug}")
    record_path = rows[0]["path"]
    try:
        record = json.loads(Path(record_path).read_text())
    except Exception as e:
        fail(f"cannot read upload_record at {record_path}: {e}")
    video_id = record.get("video_id")
    if not video_id:
        fail(f"video_id missing in {record_path}")

    from google.oauth2.credentials import Credentials
    from googleapiclient.discovery import build as build_api
    from googleapiclient.errors import HttpError

    cred_json = json.loads(TOKEN_PATH.read_text())
    creds = Credentials(token=None, refresh_token=cred_json["refresh_token"],
        client_id=cred_json["client_id"], client_secret=cred_json["client_secret"],
        token_uri="https://oauth2.googleapis.com/token", scopes=cred_json["scopes"])
    yt = build_api("youtube", "v3", credentials=creds)

    try:
        current = yt.videos().list(id=video_id, part="status,snippet").execute()
    except HttpError as e:
        fail(f"YouTube videos.list failed: {e}")
    if not current.get("items"):
        fail(f"YouTube video {video_id} not found (deleted?)")
    cur_status = current["items"][0]["status"]["privacyStatus"]
    title = current["items"][0]["snippet"]["title"]
    sys.stderr.write(f"  video {video_id} ({title}): {cur_status} → {args.privacy}\n")

    if cur_status == args.privacy:
        return out({"ok": True, "video_id": video_id, "url": f"https://youtu.be/{video_id}",
                    "privacy": args.privacy, "changed": False, "note": "already at target privacy"})

    body = {"id": video_id, "status": {"privacyStatus": args.privacy}}
    try:
        resp = yt.videos().update(part="status", body=body).execute()
    except HttpError as e:
        fail(f"YouTube videos.update failed: {e}")
    new_status = resp.get("status", {}).get("privacyStatus")

    # DB audit (write video_publish event on the latest video task)
    task_rows = seo_os_db.query_json(
        """SELECT id FROM seo_os.tasks
           WHERE slug=%s AND assigned_agent='video-producer'
           ORDER BY created_at DESC LIMIT 1""", [args.slug])
    if task_rows:
        seo_os_db.query_json(
            """INSERT INTO seo_os.workflow_events (task_id, event_type, actor_type, actor_id, message)
               VALUES (%s, 'video_uploaded', 'agent', 'video-producer', %s)""",
            [task_rows[0]["id"], f"privacyStatus changed: {cur_status} → {new_status} (video_id={video_id})"])

    return out({"ok": True, "video_id": video_id, "url": f"https://youtu.be/{video_id}",
                "title": title, "previous_privacy": cur_status, "new_privacy": new_status, "changed": True})


def build():
    p = argparse.ArgumentParser(prog="seo-video-make")
    sub = p.add_subparsers(dest="cmd", required=True)
    pp = sub.add_parser("produce", help="Article cms_draft → YouTube video")
    pp.add_argument("--brief", required=True, help="Path to brief.json")
    pp.add_argument("--slug", required=True)
    pp.add_argument("--post-id", type=int, default=None, help="Payload post id")
    pp.add_argument("--task-id", default=None, help="Parent task uuid (chain)")
    pp.add_argument("--output", default=None, help="Output dir (default ~/workspace/ohya/<slug>-video)")
    pp.add_argument("--no-upload", action="store_true", help="Render only, skip YouTube upload")
    pp.add_argument("--replace-video-id", default=None, help="Old YouTube video_id to delete before upload (for redo)")
    pp.set_defaults(func=cmd_produce)

    ps = sub.add_parser("status", help="Show video tasks for slug")
    ps.add_argument("--slug", required=True)
    ps.set_defaults(func=cmd_status)

    pb = sub.add_parser("publish", help="Change YouTube privacyStatus (private→public/unlisted)")
    pb.add_argument("--slug", required=True)
    pb.add_argument("--privacy", default="public", choices=["public", "unlisted", "private"])
    pb.set_defaults(func=cmd_publish)

    return p


if __name__ == "__main__":
    args = build().parse_args()
    args.func(args)
