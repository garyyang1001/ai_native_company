#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-video-make — Article cms_draft → YouTube video (one-shot).

Closed-loop spec ref: §3.5 (video pipeline, 2026-05-04 added)

Pipeline:
  brief.json (LLM-authored by video-producer agent)
    → fish.audio TTS x N chapters (Gary voice ef626025..., speed from brief or default 1.25)
    → HTML composition (ohya design system, 5 layouts: cover/stages/pillars/contrast/cta)
    → hyperframes render → MP4
    → thumbnail HTML + chrome headless capture → PNG
    → YouTube delete-old (if --replace existing) + upload + thumbnail + caption
    → seo_os DB rows (task + 8 artifacts + events)

Usage:
  seo-video-make produce --brief <path> --slug X --post-id N [--task-id UUID] [--output <dir>] [--privacy private|unlisted|public] [--no-upload]
  seo-video-make redo --brief <path> --slug X --post-id N --replace-video-id Y [--task-id UUID]
  seo-video-make status --slug X

Safety:
  - Read seo_os.* + Payload public REST + fish.audio + YouTube
  - Write: local files + seo_os tasks/artifacts/events + YouTube (insert/delete/captions/thumbnails)
  - Never touches Payload posts (cms-draft-executor's job)
"""
from __future__ import annotations

