      .ch-cta-block {{ margin-top:80px; max-width:1400px; padding-top:32px; border-top:1px solid var(--ohya-ink); }}
      .ch-cta-label {{ font-size:12px; letter-spacing:0.1em; color:var(--ohya-gray); }}
      .ch-cta-text {{ font-size:32px; font-weight:300; letter-spacing:0.025em; line-height:1.3; margin-top:16px; }}
      .ch-cta-url {{ font-size:14px; letter-spacing:0.05em; color:var(--ohya-gray); margin-top:24px; font-feature-settings:"tnum" 1; }}
