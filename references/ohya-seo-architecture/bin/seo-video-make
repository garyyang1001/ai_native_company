      /* pillars */
      .ch-pillar-rows {{ display:grid; grid-template-columns:200px 1fr; row-gap:32px; column-gap:64px; }}
      .pillar-label {{ font-size:24px; font-weight:400; padding-top:8px; border-top:1px solid var(--ohya-ink); }}
      .pillar-body {{ font-size:18px; line-height:1.7; padding-top:8px; border-top:0.5px solid var(--ohya-line); font-weight:300; }}
      /* contrast */
      .ch-contrast-grid {{ display:grid; grid-template-columns:1fr 1fr; gap:0; margin-top:64px; border-top:1px solid var(--ohya-ink); }}
