'''


# ---------- 3. Render with hyperframes ----------
def render_video(html_path: Path, output_dir: Path) -> Path:
    """Run hyperframes render. Returns mp4 path."""
    cmd = ["npx", "--yes", "hyperframes@0.4.42", "render"]
    sys.stderr.write(f"  rendering {html_path}...\n")
    r = subprocess.run(cmd, cwd=str(html_path.parent), capture_output=True, text=True, timeout=900)
    if r.returncode != 0:
        raise RuntimeError(f"hyperframes render failed: {r.stderr[-2000:]}")
    # Find newest mp4 in renders/
    renders = output_dir / "renders"
    mp4s = sorted([f for f in renders.iterdir() if f.suffix == ".mp4"], key=lambda f: f.stat().st_mtime)
    if not mp4s:
        raise RuntimeError("no mp4 found after render")
    return mp4s[-1]


