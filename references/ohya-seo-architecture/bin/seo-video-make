OHYA_BG = "#F5F5F0"
OHYA_GRAY = "#8C8C88"
OHYA_LINE = "#E0E0D8"
OHYA_RED = "#C84630"


def out(data, code=0):
    print(json.dumps(data, ensure_ascii=False, indent=2, default=str))
    sys.exit(code)


def fail(msg, code=1):
    out({"ok": False, "error": msg}, code)


# ---------- env / deps ----------
def load_env():
    """Load fish.audio + YouTube credentials."""
    from dotenv import load_dotenv
    load_dotenv(str(ENV_FILE))


# ---------- 1. Generate narration audio per chapter ----------
def synthesize_chapter_audio(chapters, audio_dir: Path, speed: float):
    """Call fish.audio S2-Pro for each chapter narration. Returns dict {id: duration}."""
    import msgpack, requests
    audio_dir.mkdir(parents=True, exist_ok=True)
    durations = {}
    for i, ch in enumerate(chapters, 1):
        out_path = audio_dir / f"{i:02d}-{ch['id']}.mp3"
        body = msgpack.packb({
            "text": ch["narration"],
            "reference_id": os.environ["FISH_REFERENCE_ID"],
            "format": "mp3",
            "mp3_bitrate": 128,
            "normalize": True,
            "prosody": {"speed": speed},
            "chunk_length": 180,
        }, use_bin_type=True)
        r = requests.post(
            "https://api.fish.audio/v1/tts",
            headers={
                "Authorization": f"Bearer {os.environ['FISH_API_KEY']}",
                "Content-Type": "application/msgpack",
                "model": "s2-pro",
            },
            data=body, timeout=180,
        )
        if r.status_code != 200:
            raise RuntimeError(f"fish.audio TTS failed: {r.status_code} {r.text[:300]}")
        out_path.write_bytes(r.content)
        # ffprobe duration
        rr = subprocess.run(
            ["ffprobe", "-v", "error", "-show_entries", "format=duration", "-of", "default=nw=1:nk=1", str(out_path)],
            capture_output=True, text=True,
        )
        durations[ch["id"]] = float(rr.stdout.strip())
        sys.stderr.write(f"  audio: {out_path.name} {durations[ch['id']]:.2f}s\n")
    return durations


# ---------- 2. Compose HTML (5 layouts, ohya design) ----------
LAYOUT_RENDERERS = {}


def layout(name):
    def deco(fn):
        LAYOUT_RENDERERS[name] = fn
        return fn
    return deco


@layout("cover")
def render_cover(scene_id: str, c: dict) -> str:
    """Cover: kicker + hero title + rule + lede + byline."""
    return f'''
      <div class="ch-cover">
        <div class="ch-kicker">{c.get("kicker", "")}</div>
        <h1 class="ch-hero">{c["hero"].replace(chr(10), "<br>")}</h1>
        <div class="ch-rule"></div>
        <div class="ch-lede">{c.get("lede", "")}</div>
        <div class="ch-byline">{c.get("byline", "")}</div>
      </div>'''


@layout("stages")
def render_stages(scene_id: str, c: dict) -> str:
    """Stage table: title + sub + N stages (current marked red) + caption."""
    stages_html = "".join(
        f'<div class="stage{ " stage-current" if s.get("current") else ""}">'
        f'{("<span class=stage-mark></span>" if s.get("current") else "")}'
        f'<div class="stage-num">{s["num"]}</div>'
        f'<div class="stage-name">{s["name"].replace(chr(10), "<br>")}</div>'
        f'<div class="stage-desc">{s.get("desc", "").replace(chr(10), "<br>")}</div></div>'
        for s in c["stages"]
    )
    return f'''
      <div class="ch-stages">
        <h2 class="ch-title">{c["title"]}</h2>
        <div class="ch-sub">{c.get("sub", "")}</div>
        <div class="ch-stage-grid" style="grid-template-columns: repeat({len(c["stages"])}, 1fr)">{stages_html}</div>
        <div class="ch-caption">{c.get("caption", "")}</div>
      </div>'''


@layout("pillars")
def render_pillars(scene_id: str, c: dict) -> str:
    """Editorial label / body rows."""
    rows = "".join(
        f'<div class="pillar-label">{p["label"]}</div>'
        f'<div class="pillar-body">{p["body"]}</div>'
        for p in c["pillars"]
    )
    return f'''
      <div class="ch-pillars">
        <h2 class="ch-title">{c["title"].replace(chr(10), "<br>")}</h2>
        <div class="ch-rule"></div>
        <div class="ch-pillar-rows">{rows}</div>
      </div>'''


@layout("contrast")
def render_contrast(scene_id: str, c: dict) -> str:
    """2-col contrast + Q list + verdict (red accent)."""
    q_lines = "".join(f'<div class="ch-q-line">{q}</div>' for q in c.get("questions", []))
    verdict = c.get("verdict", "")
    if "[ACCENT]" in verdict:
        verdict = verdict.replace("[ACCENT]", '<span class="accent">').replace("[/ACCENT]", "</span>")
    return f'''
      <div class="ch-contrast">
        <h2 class="ch-title">{c["title"].replace(chr(10), "<br>")}</h2>
        <div class="ch-sub">{c.get("sub", "")}</div>
        <div class="ch-contrast-grid">
          <div class="ch-contrast-col">
            <div class="ch-tag">{c["left"]["tag"]}</div>
            <div class="ch-claim">{c["left"]["claim"].replace(chr(10), "<br>")}</div>
          </div>
          <div class="ch-contrast-col">
            <div class="ch-tag ch-tag-red">{c["right"]["tag"]}</div>
            <div class="ch-claim">{c["right"]["claim"].replace(chr(10), "<br>")}</div>
          </div>
        </div>
        <div class="ch-q">{q_lines}</div>
        <div class="ch-verdict">{verdict}</div>
      </div>'''


@layout("cta")
def render_cta(scene_id: str, c: dict) -> str:
    """Closing CTA: tag + hero + items + cta block."""
    items = "".join(
        f'<div class="ch-item"><div class="ch-item-num">{i+1:02d}</div>'
        f'<div class="ch-item-text">{x}</div></div>'
        for i, x in enumerate(c.get("items", []))
    )
    return f'''
      <div class="ch-cta-page">
        <div class="ch-tag">{c.get("tag", "")}</div>
        <h2 class="ch-title">{c["title"].replace(chr(10), "<br>")}</h2>
        <div class="ch-rule"></div>
        <div class="ch-list" style="grid-template-columns: repeat({max(1,len(c.get("items",[])))}, 1fr)">{items}</div>
        <div class="ch-cta-block">
          <div class="ch-cta-label">{c["cta"]["label"]}</div>
          <div class="ch-cta-text">{c["cta"]["text"].replace(chr(10), "<br>")}</div>
          <div class="ch-cta-url">{c["cta"]["url"]}</div>
        </div>
      </div>'''


def build_composition_html(brief: dict, durations: dict, audio_dir_rel: str = "assets/audio") -> str:
    """Assemble full composition with 5 chapters, ohya design tokens, GSAP timeline."""
    chapters = brief["chapters"]
    total_pages = len(chapters)
    # Compute timeline (start, dur) per chapter with 0.01 floating-point gap
    cursor = 0.0
    timeline_entries = []
    audio_entries = []
    scene_blocks = []
    gsap_lines = []
    for i, ch in enumerate(chapters, 1):
        start = round(cursor + (0.01 if i > 1 else 0), 2)
        dur = round(durations[ch["id"]] - 0.01, 2)
        cursor = start + dur
        scene_id = f"scene-{i}-{ch['id']}"
        renderer = LAYOUT_RENDERERS.get(ch["layout"])
        if not renderer:
            raise ValueError(f"Unknown layout: {ch['layout']}")
        inner = renderer(scene_id, ch["content"])
        page_label = f"第 {i:02d} 頁　／　共 {total_pages:02d} 頁"
        kicker_top = ch.get("content", {}).get("top_label", brief.get("brand_name", "好事發生數位　／　OHYA DIGITAL"))
        scene_blocks.append(f'''
      <div id="{scene_id}" class="clip full" data-start="{start}" data-duration="{dur}" data-track-index="1">
        <div class="top-bar"><span class="left">{kicker_top}</span><span>{page_label}</span></div>
        {inner}
        <div class="footer-bar"><span>{brief.get("source_url","")}</span><span>{brief.get("year","2026")}</span></div>
      </div>''')
        audio_entries.append(
            f'<audio id="audio-{i}" src="{audio_dir_rel}/{i:02d}-{ch["id"]}.mp3" '
            f'data-start="{start}" data-duration="{dur}" data-track-index="2"></audio>'
        )
        # Generic GSAP fade-in for each scene's main content
        gsap_lines.append(
            f'tl.from("#{scene_id} > div:not(.top-bar):not(.footer-bar)", '
            f'{{ opacity: 0, y: 16, duration: 0.9, ease: "cubic-bezier(0.25,0.46,0.45,0.94)" }}, {start + 0.3});'
        )

    total_dur = round(cursor + 1, 0)

    css = f'''
      :root {{
        --ohya-ink: {OHYA_INK}; --ohya-bg: {OHYA_BG}; --ohya-gray: {OHYA_GRAY};
        --ohya-line: {OHYA_LINE}; --ohya-red: {OHYA_RED};
      }}
      * {{ margin:0; padding:0; box-sizing:border-box; }}
      html, body {{ width:1920px; height:1080px; overflow:hidden; background:var(--ohya-bg); color:var(--ohya-ink); font-family:"Noto Sans TC","PingFang TC","Microsoft JhengHei",sans-serif; font-weight:300; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility; }}
      .clip {{ position:absolute; inset:0; }}
      .full {{ width:100%; height:100%; padding:96px 128px; display:flex; flex-direction:column; }}
      .top-bar, .footer-bar {{ display:flex; justify-content:space-between; align-items:center; font-size:12px; letter-spacing:0.1em; color:var(--ohya-gray); font-weight:400; }}
      .top-bar {{ padding-bottom:24px; border-bottom:0.5px solid var(--ohya-line); }}
      .top-bar .left {{ color:var(--ohya-ink); }}
      .footer-bar {{ margin-top:auto; padding-top:24px; border-top:0.5px solid var(--ohya-line); }}
      .ch-title {{ font-size:36px; font-weight:300; letter-spacing:0.05em; line-height:1.3; margin-top:64px; max-width:1400px; }}
      .ch-sub {{ font-size:14px; letter-spacing:0.1em; color:var(--ohya-gray); margin-top:16px; }}
      .ch-rule {{ width:80px; height:1px; background:var(--ohya-ink); margin:32px 0 48px 0; }}
      .ch-tag {{ font-size:12px; letter-spacing:0.1em; color:var(--ohya-gray); }}
      .ch-tag-red {{ color:var(--ohya-red); }}
      /* cover */
      .ch-kicker {{ font-size:12px; letter-spacing:0.1em; color:var(--ohya-gray); margin-top:96px; }}
      .ch-hero {{ font-size:90px; font-weight:300; letter-spacing:0.05em; line-height:1.2; margin-top:32px; max-width:1400px; }}
      .ch-cover .ch-rule {{ margin:64px 0 32px 0; }}
      .ch-lede {{ font-size:24px; line-height:1.4; letter-spacing:0.025em; font-weight:400; max-width:1100px; }}
      .ch-byline {{ font-size:14px; letter-spacing:0.1em; color:var(--ohya-gray); margin-top:24px; }}
      /* stages */
      .ch-stage-grid {{ display:grid; gap:0; margin-top:80px; border-top:1px solid var(--ohya-ink); border-bottom:0.5px solid var(--ohya-line); }}
      .stage {{ padding:32px 24px; border-right:0.5px solid var(--ohya-line); position:relative; min-height:380px; display:flex; flex-direction:column; }}
