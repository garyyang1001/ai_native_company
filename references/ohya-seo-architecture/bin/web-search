#!/usr/bin/env python3
"""DuckDuckGo search helper. Zero dependencies beyond stdlib.
Usage: web-search "AI 導入企業 2026"
Returns: JSON array of {title, url, description} top 10 results.
"""
import json, sys, urllib.request, urllib.parse, re, html

def ddg_search(query, num=10):
    url = "https://html.duckduckgo.com/html/?" + urllib.parse.urlencode({"q": query})
    req = urllib.request.Request(url, headers={
        "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0",
    })
    with urllib.request.urlopen(req, timeout=15) as resp:
        body = resp.read().decode("utf-8", errors="replace")

    results = []
    for m in re.finditer(
        r'<a rel="nofollow" class="result__a" href="([^"]+)"[^>]*>(.*?)</a>.*?'
        r'<a class="result__snippet"[^>]*>(.*?)</a>',
        body, re.DOTALL
    ):
        href, title_html, desc_html = m.groups()
        parsed = urllib.parse.parse_qs(urllib.parse.urlparse(href).query)
        real_url = parsed.get("uddg", [href])[0]
        title = html.unescape(re.sub(r"<[^>]+>", "", title_html)).strip()
        desc = html.unescape(re.sub(r"<[^>]+>", "", desc_html)).strip()
        if title and real_url.startswith("http"):
            results.append({"title": title, "url": real_url, "description": desc})
        if len(results) >= num:
            break
    return results

if __name__ == "__main__":
    query = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else ""
    if not query:
        print("Usage: web-search <query>", file=sys.stderr)
        sys.exit(1)
    results = ddg_search(query)
    print(json.dumps(results, ensure_ascii=False, indent=2))
