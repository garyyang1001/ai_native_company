#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-dispatch-with-guardrail — subprocess dispatch wrapper with guardrail hooks.

Use this for coordinator/automation dispatch when a real Ohya content agent is spawned.
It runs:
1. pre_dispatch guardrail before subprocess
2. Hermes profile subprocess (unless --dry-run)
3. post_agent_run guardrail after process exits when --expected-output is supplied

It does not deploy, push, run migrations, or write Payload. It may persist guardrail
results into seo_os when --persist-db is set.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import mimetypes
import os
import shlex
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path('/Users/garyyang/clients/ohya') / 'lib'))
from seo_agent_contract import build_contract, evaluate_artifact_type_policy  # noqa: E402

ROOT = Path('/Users/garyyang/clients/ohya')
HERMES_PY = '/Users/garyyang/.hermes/hermes-agent/venv/bin/python'
GUARDRAIL = ROOT / 'bin' / 'seo-guardrail'
AUTH_HEALTHCHECK = ROOT / 'bin' / 'ohya-profile-auth-healthcheck'
LOG_ROOT = ROOT / 'profiles' / 'coordinator' / 'logs' / 'guarded-dispatch'


def write_context(ctx: dict, prefix: str) -> str:
    fd, path = tempfile.mkstemp(prefix=prefix, suffix='.json')
    with os.fdopen(fd, 'w') as fh:
        json.dump(ctx, fh, ensure_ascii=False, indent=2, default=str)
    return path


def run_guardrail(stage: str, ctx: dict, *, persist_db: bool, write_log: bool = True) -> dict:
    path = write_context(ctx, f'seo-guardrail-{stage}-')
    cmd = [str(GUARDRAIL), 'check', '--stage', stage.replace('_', '-'), '--context', path, '--json']
    if write_log:
        cmd.append('--write-log')
    if persist_db:
        cmd.append('--persist-db')
    cp = subprocess.run(cmd, cwd=str(ROOT), text=True, capture_output=True, timeout=120)
    try:
        data = json.loads(cp.stdout)
    except Exception:
        data = {'ok': False, 'parse_error': True, 'stdout_preview': cp.stdout[:1000], 'stderr_preview': cp.stderr[:1000]}
    data['process_exit_code'] = cp.returncode
    data['context_path'] = path
    return data


def pre_dispatch_context(args) -> dict:
    return {
        'stage': 'pre_dispatch',
        'task': {
            'task_id': args.task_id,
            'task_type': args.task_type,
            'owner_agent': args.profile,
            'target_slug': args.slug,
            'post_id': args.post_id,
        },
        'source_request': {'text': args.source_text or args.prompt[:500]},
    }


def post_agent_context(args, proc: subprocess.CompletedProcess, started_at: str, stdout_path: Path, stderr_path: Path, contract: dict | None = None) -> dict:
    artifacts = {}
    contract = contract or {}
    paths = [a.get('path') for a in contract.get('artifacts') or [] if a.get('path')]
    if paths:
        artifacts['expected_output'] = paths[0]
        artifacts['all_outputs'] = paths
    elif args.expected_output:
        artifacts['expected_output'] = args.expected_output
    if args.audit_json:
        artifacts['audit_json'] = args.audit_json
    return {
        'stage': 'post_agent_run',
        'task': {
            'task_id': args.task_id,
            'task_type': args.task_type,
            'owner_agent': args.profile,
            'target_slug': args.slug,
            'started_at': started_at,
        },
        'agent_run': {
            'agent': args.profile,
            'exit_code': proc.returncode,
            'started_at': started_at,
            'stdout_path': str(stdout_path),
            'stderr_path': str(stderr_path),
            # Do not put full stdout/stderr here; guardrail scans short previews only.
            'stdout': stdout_path.read_text(errors='ignore')[:2000] if stdout_path.exists() else '',
            'stderr': stderr_path.read_text(errors='ignore')[:2000] if stderr_path.exists() else '',
            'artifact_contract': contract,
        },
        'artifacts': artifacts,
        'artifact_policy': evaluate_artifact_type_policy(profile=args.profile, task_type=args.task_type, contract=contract),
        'audit': {'path': args.audit_json} if args.audit_json else {},
    }


def _valid_uuid(value: str) -> bool:
    try:
        import uuid
        uuid.UUID(str(value))
        return True
    except Exception:
        return False


def _load_db():
    sys.path.insert(0, str(ROOT / 'lib'))
    import seo_os_db  # noqa: WPS433
    return seo_os_db


def _followup_type_for_failure(metadata: dict, original_type: str) -> tuple[str, str, str]:
    guardrail = metadata.get('guardrail') or {}
    contract = metadata.get('artifact_contract') or {}
    failed = set(guardrail.get('failed_guardrails') or [])
    failure_state = guardrail.get('failure_state')
    profile = metadata.get('agent') or metadata.get('profile')
    if (
        'post_agent_artifact_must_exist' in failed
        or 'post_agent_artifact_type_contract' in failed
        or failure_state in {'blocked_missing_agent_output', 'blocked_artifact_type_mismatch'}
    ):
        if original_type in {'write', 'article_refresh'} or profile == 'writer':
            return 'write', 'retry_writer_missing_final_article', 'Retry writer: missing or invalid final_article artifact.'
        if original_type in {'audit', 'pre_publish_audit', 'refresh'} or profile == 'article-editor':
            return 'audit', 'retry_editor_missing_audit_artifact', 'Retry article-editor: missing or invalid audit artifact.'
        if original_type == 'link_fix' or profile == 'link-finder':
            return 'link_fix', 'retry_link_finder_missing_link_audit', 'Retry link-finder: missing or invalid link audit artifact.'
        return original_type, 'retry_missing_artifact', 'Retry after agent run failed to produce required artifact contract.'
    if 'post_agent_audit_no_critical' in failed or failure_state == 'blocked_audit_failed':
        return 'refresh', 'fix_audit_blocker', 'Fix task after audit found blocking issue.'
    if metadata.get('policy_decision') in ('policy_exception', 'destructive_requires_approval'):
        return 'query', 'policy_exception_review', 'Review policy exception before continuing workflow.'
    if contract and not contract.get('ok'):
        return original_type, 'fix_artifact_contract', 'Fix agent artifact contract output before continuing workflow.'
    return original_type, 'retry_guardrail_failure', 'Retry after guardrail blocked workflow.'


def _create_followup_task_if_possible(args, *, metadata: dict) -> dict:
    if not args.persist_db or not getattr(args, 'create_followup_on_failure', True):
        return {'ok': True, 'skipped': True, 'reason': 'disabled'}
    if not _valid_uuid(str(args.task_id)):
        return {'ok': True, 'skipped': True, 'reason': 'task_id is not UUID'}

    # A pre_dispatch block means the agent never ran; retrying the same task with
    # the same task_type/agent/source_text will deterministically hit the same
    # guardrail again. Creating an automatic follow-up here caused a 60-second
    # retry loop (`Retry after guardrail blocked workflow.` contains the word
    # "guardrail", which is intentionally classified as dev/infra text).
    if metadata.get('blocked_by') == 'pre_dispatch':
        guardrail = metadata.get('guardrail') or {}
        return {
            'ok': True,
            'skipped': True,
            'reason': 'no_auto_retry_for_pre_dispatch_block',
            'failure_state': guardrail.get('failure_state'),
            'failed_guardrails': guardrail.get('failed_guardrails') or [],
            'secret_redacted': True,
        }

    try:
        seo_os_db = _load_db()
        follow_type, follow_kind, summary = _followup_type_for_failure(metadata, args.task_type)
        rows = seo_os_db.query_json(
            """
            INSERT INTO seo_os.tasks (source, type, status, priority, slug, payload_post_id, assigned_agent, parent_task_id, input_summary, metadata)
            VALUES ('system', %s, 'pending', 'medium', %s, %s, %s, %s, %s, %s::jsonb)
            RETURNING id, type, status, slug, assigned_agent, parent_task_id
            """,
            [
                follow_type,
                args.slug,
                args.post_id,
                args.profile,
                args.task_id,
                summary,
                json.dumps({'generated_by': 'seo-dispatch-with-guardrail', 'followup_kind': follow_kind, 'parent_failure': metadata}, ensure_ascii=False, default=str),
            ],
        )
        row = rows[0] if rows else {}
        seo_os_db.record_workflow_event(
            task_id=args.task_id,
            event_type='next_task_created',
            actor_type='system',
            actor_id='seo-dispatch-with-guardrail',
            message=f"created follow-up task {row.get('id')} ({follow_kind})",
            metadata={'followup_task_id': str(row.get('id')) if row.get('id') else None, 'followup_kind': follow_kind},
        )
        return {'ok': True, 'followup_task': row, 'secret_redacted': True}
    except Exception as exc:
        return {'ok': False, 'error_type': type(exc).__name__, 'error': str(exc), 'secret_redacted': True}


def _mark_task_failed_if_possible(args, *, reason: str, metadata: dict) -> dict:
    """Best-effort local DB write: mark real UUID task failed and record event.

    Non-UUID fixture task ids are intentionally ignored so local CLI tests stay DB-free.
    """
    if not args.persist_db:
        return {'ok': True, 'skipped': True, 'reason': 'persist_db disabled'}
    if not _valid_uuid(str(args.task_id)):
        return {'ok': True, 'skipped': True, 'reason': 'task_id is not UUID'}
    try:
        seo_os_db = _load_db()
        updated = seo_os_db.query_json(
            """
            UPDATE seo_os.tasks
            SET status='failed', updated_at=now(), metadata = COALESCE(metadata, '{}'::jsonb) || %s::jsonb
            WHERE id=%s AND status <> 'done'
            RETURNING id, status
            """,
            [json.dumps({'guarded_dispatch_failure': metadata}, ensure_ascii=False, default=str), args.task_id],
        )
        event = seo_os_db.record_workflow_event(
            task_id=args.task_id,
            event_type='task_failed',
            actor_type='system',
            actor_id='seo-dispatch-with-guardrail',
            message=reason,
            metadata=metadata,
        )
        followup = _create_followup_task_if_possible(args, metadata=metadata)
        return {'ok': True, 'updated_task': bool(updated), 'workflow_event_id': str(event.get('id')) if event.get('id') else None, 'followup': followup, 'secret_redacted': True}
    except Exception as exc:
        return {'ok': False, 'error_type': type(exc).__name__, 'error': str(exc), 'secret_redacted': True}


def _create_agent_run_if_possible(args, *, started_at: str, stdout_path: Path, stderr_path: Path) -> dict:
    if not args.persist_db or not _valid_uuid(str(args.task_id)):
        return {'ok': True, 'skipped': True, 'reason': 'persist_db disabled or task_id not UUID'}
    try:
        seo_os_db = _load_db()
        rows = seo_os_db.query_json(
            """
            INSERT INTO seo_os.agent_runs (task_id, agent, profile, started_at, status, input_prompt, stdout_path, stderr_path, metadata)
            VALUES (%s, %s, %s, %s::timestamptz, 'running', %s, %s, %s, %s::jsonb)
            RETURNING id, status, started_at
            """,
            [
                args.task_id,
                args.profile,
                args.profile,
                started_at,
                args.prompt,
                str(stdout_path),
                str(stderr_path),
                json.dumps({'created_by': 'seo-dispatch-with-guardrail', 'local_only': True}, ensure_ascii=False),
            ],
        )
        row = rows[0] if rows else {}
        return {'ok': True, 'agent_run': row, 'agent_run_id': str(row.get('id')) if row.get('id') else None, 'secret_redacted': True}
    except Exception as exc:
        return {'ok': False, 'error_type': type(exc).__name__, 'error': str(exc), 'secret_redacted': True}


def _update_agent_run_if_possible(agent_run_id: str | None, *, status: str, exit_code: int | None, final_message: str | None, error_message: str | None = None, contract: dict | None = None) -> dict:
    if not agent_run_id:
        return {'ok': True, 'skipped': True, 'reason': 'no agent_run_id'}
    try:
        seo_os_db = _load_db()
        rows = seo_os_db.query_json(
            """
            UPDATE seo_os.agent_runs
            SET ended_at=now(), status=%s, exit_code=%s, final_message=%s, error_message=%s,
                duration_seconds=GREATEST(0, EXTRACT(EPOCH FROM (now() - started_at))::int),
                metadata = COALESCE(metadata,'{}'::jsonb) || %s::jsonb
            WHERE id=%s
            RETURNING id, status, exit_code, duration_seconds
            """,
            [status, exit_code, final_message, error_message, json.dumps({'artifact_contract': contract or {}}, ensure_ascii=False, default=str), agent_run_id],
        )
        return {'ok': True, 'agent_run': rows[0] if rows else None, 'secret_redacted': True}
    except Exception as exc:
        return {'ok': False, 'error_type': type(exc).__name__, 'error': str(exc), 'secret_redacted': True}


def _file_meta(path: Path) -> dict:
    h = hashlib.sha256()
    with path.open('rb') as fh:
        for chunk in iter(lambda: fh.read(1024 * 1024), b''):
            h.update(chunk)
    return {'sha256': h.hexdigest(), 'size_bytes': path.stat().st_size, 'mime_type': mimetypes.guess_type(str(path))[0] or 'application/octet-stream'}


def _artifact_type_from_path(path: Path, default: str = 'other') -> str:
    name = path.name.lower()
    if 'final' in name and 'article' in name:
        return 'final_article'
    if 'audit' in name:
        return 'audit_report'
    if 'patch' in name:
        return 'patch_plan'
    if 'fix' in name:
        return 'fix_queue'
    return default


def _db_artifact_contract_if_possible(args, *, started_at: str, agent_run_id: str | None = None) -> dict:
    """Use artifacts already registered by the child agent as post_agent evidence.

    Some narrow agents correctly register artifacts directly into seo_os.artifacts
    but do not print the new ARTIFACT contract marker yet. This fallback prevents
    false negatives while the agent SOUL/helpers are being upgraded.
    """
    if not args.persist_db or not _valid_uuid(str(args.task_id)):
        return {'ok': False, 'artifacts': [], 'artifact_count': 0, 'reason': 'persist disabled or task_id not UUID', 'secret_redacted': True}
    try:
        seo_os_db = _load_db()
        rows = seo_os_db.query_json(
            """
            SELECT id::text, type, path, google_doc_url, url, summary, metadata
            FROM seo_os.artifacts
            WHERE task_id=%s
              AND status='active'
              AND created_at >= (%s::timestamptz - interval '5 minutes')
            ORDER BY created_at DESC
            LIMIT 10
            """,
            [args.task_id, started_at],
        )
        artifacts = []
        for row in rows:
            path = Path(row.get('path') or '')
            if not path.exists() or not path.is_file() or path.stat().st_size <= 0:
                continue
            metadata = row.get('metadata') if isinstance(row.get('metadata'), dict) else {}
            metadata = {**metadata, 'source': 'db_existing_artifact', 'artifact_id': row.get('id')}
            artifacts.append({
                'path': str(path),
                'type': row.get('type') or _artifact_type_from_path(path),
                'summary': row.get('summary'),
                'google_doc_url': row.get('google_doc_url'),
                'url': row.get('url'),
                'metadata': metadata,
            })
            if agent_run_id and row.get('id'):
                seo_os_db.query_json(
                    "UPDATE seo_os.artifacts SET agent_run_id=COALESCE(agent_run_id, %s) WHERE id=%s RETURNING id",
                    [agent_run_id, row.get('id')],
                )
        return {'ok': bool(artifacts), 'artifacts': artifacts, 'artifact_count': len(artifacts), 'secret_redacted': True}
    except Exception as exc:
        return {'ok': False, 'artifacts': [], 'artifact_count': 0, 'error_type': type(exc).__name__, 'error': str(exc), 'secret_redacted': True}


def _record_artifacts_if_possible(args, *, post_result: dict, contract: dict, agent_run_id: str | None = None) -> dict:
    if not args.persist_db:
        return {'ok': True, 'skipped': True, 'reason': 'persist disabled'}
    if not _valid_uuid(str(args.task_id)):
        return {'ok': True, 'skipped': True, 'reason': 'task_id is not UUID'}
    artifacts = contract.get('artifacts') or []
    if not artifacts:
        return {'ok': False, 'error': 'no artifacts in contract', 'secret_redacted': True}
    recorded = []
    missing = []
    try:
        seo_os_db = _load_db()
        for item in artifacts:
            if (item.get('metadata') or {}).get('source') == 'db_existing_artifact':
                recorded.append({'path': item.get('path'), 'type': item.get('type'), 'existing_artifact_id': (item.get('metadata') or {}).get('artifact_id'), 'reused': True})
                continue
            path = Path(item.get('path') or '')
            if not path.exists() or not path.is_file():
                missing.append(str(path))
                continue
            meta = _file_meta(path)
            artifact_type = item.get('type') or args.artifact_type or _artifact_type_from_path(path)
            rows = seo_os_db.query_json(
                """
                INSERT INTO seo_os.artifacts (task_id, agent_run_id, type, path, google_doc_url, slug, url, agent, summary, status, sha256, mime_type, size_bytes, metadata)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, 'active', %s, %s, %s, %s::jsonb)
                RETURNING id, type, path, slug, status, sha256, size_bytes, agent_run_id
                """,
                [
                    args.task_id,
                    agent_run_id,
                    artifact_type,
                    str(path),
                    item.get('google_doc_url'),
                    args.slug,
                    item.get('url'),
                    args.profile,
                    item.get('summary') or args.artifact_summary or f"{args.profile} output for {args.task_type}",
                    meta['sha256'], meta['mime_type'], meta['size_bytes'],
                    json.dumps({'recorded_by': 'seo-dispatch-with-guardrail', 'post_agent_result_id': post_result.get('result_id'), 'contract_metadata': item.get('metadata') or {}}, ensure_ascii=False, default=str),
                ],
            )
            row = rows[0] if rows else {}
            recorded.append(row)
            seo_os_db.record_workflow_event(
                task_id=args.task_id,
                agent_run_id=agent_run_id,
                event_type='artifact_created',
                actor_type='system',
                actor_id='seo-dispatch-with-guardrail',
                message=f"indexed artifact {row.get('id')} from agent contract",
                metadata={'artifact_id': str(row.get('id')) if row.get('id') else None, 'artifact_type': artifact_type, 'path': str(path)},
            )
        return {'ok': bool(recorded) and not missing, 'artifacts': recorded, 'artifact_count': len(recorded), 'missing_paths': missing, 'secret_redacted': True}
    except Exception as exc:
        return {'ok': False, 'error_type': type(exc).__name__, 'error': str(exc), 'recorded_count': len(recorded), 'missing_paths': missing, 'secret_redacted': True}


def _run_profile_auth_repair(profile: str) -> dict:
    """Best-effort local auth self-healing before spawning a narrow profile.

    This copies coordinator auth only when target profile auth is missing/bad/exhausted.
    It never prints token values; helper output is secret-redacted JSON.
    """
    if not AUTH_HEALTHCHECK.exists():
        return {'ok': True, 'skipped': True, 'reason': 'auth_healthcheck_helper_missing'}
    cmd = [str(AUTH_HEALTHCHECK), '--profiles', profile, '--repair', '--json']
    try:
        cp = subprocess.run(cmd, cwd=str(ROOT), text=True, capture_output=True, timeout=90)
    except subprocess.TimeoutExpired:
        return {'ok': False, 'timeout': True, 'secret_redacted': True}
    try:
        data = json.loads(cp.stdout)
    except Exception:
        data = {'ok': False, 'parse_error': True, 'stdout_preview': (cp.stdout or '')[:1000], 'stderr_preview': (cp.stderr or '')[:1000]}
    data['process_exit_code'] = cp.returncode
    data['secret_redacted'] = True
    return data


def cmd_run(args) -> int:
    pre = run_guardrail('pre_dispatch', pre_dispatch_context(args), persist_db=args.persist_db)
    result = {
        'ok': False,
        'dry_run': args.dry_run,
        'task_id': args.task_id,
        'profile': args.profile,
        'task_type': args.task_type,
        'slug': args.slug,
        'pre_dispatch': pre,
        'local_only': True,
        'production_side_effect': False,
        'secret_redacted': True,
    }
    if not pre.get('ok'):
        result['blocked_by'] = 'pre_dispatch'
        result['failure_record'] = _mark_task_failed_if_possible(args, reason='pre_dispatch guardrail blocked dispatch', metadata={'blocked_by': 'pre_dispatch', 'guardrail': pre})
        print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
        return 1

    if args.test_command:
        cmd = shlex.split(args.test_command)
    else:
        auth_repair = _run_profile_auth_repair(args.profile)
        result['profile_auth_preflight'] = auth_repair
        if not auth_repair.get('ok'):
            result['blocked_by'] = 'profile_auth_preflight'
            result['failure_record'] = _mark_task_failed_if_possible(args, reason='profile auth preflight failed', metadata={'blocked_by': 'profile_auth_preflight', 'auth_preflight': auth_repair})
            print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
            return 1
        cmd = [
            HERMES_PY, '-m', 'hermes_cli.main', '--profile', args.profile,
            'chat', '--max-turns', str(args.max_turns), '--yolo', '-q', args.prompt,
        ]
    result['command_preview'] = [cmd[0], *(cmd[1:4] if len(cmd) > 1 else [])]
    if not args.test_command:
        result['command_preview'] = [HERMES_PY, '-m', 'hermes_cli.main', '--profile', args.profile, 'chat', '--max-turns', str(args.max_turns), '--yolo', '-q', args.prompt[:120] + ('...' if len(args.prompt) > 120 else '')]
    if args.dry_run:
        result['ok'] = True
        result['subprocess_skipped'] = True
        print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
        return 0

    LOG_ROOT.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')
    safe_task = ''.join(ch if ch.isalnum() or ch in '-_' else '_' for ch in str(args.task_id))[:80]
    stdout_path = LOG_ROOT / f'{stamp}-{safe_task}-{args.profile}.stdout.log'
    stderr_path = LOG_ROOT / f'{stamp}-{safe_task}-{args.profile}.stderr.log'
    started_at = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
    env = os.environ.copy()
    env['HERMES_HOME'] = str(ROOT)
    run_record = _create_agent_run_if_possible(args, started_at=started_at, stdout_path=stdout_path, stderr_path=stderr_path)
    agent_run_id = run_record.get('agent_run_id')
    result['agent_run_record'] = run_record
    try:
        with stdout_path.open('w') as out, stderr_path.open('w') as err:
            proc = subprocess.run(cmd, cwd=str(ROOT), env=env, text=True, stdout=out, stderr=err, timeout=args.timeout)
    except subprocess.TimeoutExpired as exc:
        stderr_path.write_text((stderr_path.read_text(errors='ignore') if stderr_path.exists() else '') + f"\nTIMEOUT after {args.timeout}s\n", encoding='utf-8')
        result['subprocess'] = {'exit_code': None, 'stdout_path': str(stdout_path), 'stderr_path': str(stderr_path), 'timeout': True}
        result['agent_run_update'] = _update_agent_run_if_possible(agent_run_id, status='timeout', exit_code=None, final_message='subprocess timeout', error_message=str(exc), contract={})
        result['failure_record'] = _mark_task_failed_if_possible(args, reason='agent subprocess timed out', metadata={'blocked_by': 'subprocess_timeout', 'timeout': args.timeout})
        print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
        return 1

    stdout_text = stdout_path.read_text(errors='ignore') if stdout_path.exists() else ''
    contract = build_contract(
        stdout_text=stdout_text,
        manifest_path=args.artifact_manifest,
        expected_output=args.expected_output,
        artifact_type=args.artifact_type,
        artifact_summary=args.artifact_summary,
    )
    if not contract.get('ok'):
        db_contract = _db_artifact_contract_if_possible(args, started_at=started_at, agent_run_id=agent_run_id)
        if db_contract.get('ok'):
            contract = db_contract
            contract['source'] = 'db_existing_artifact_fallback'
    result['artifact_contract'] = contract
    result['subprocess'] = {'exit_code': proc.returncode, 'stdout_path': str(stdout_path), 'stderr_path': str(stderr_path)}

    # A1 enforcement: every non-dry-run dispatch must pass post_agent_run.
    # Artifact contract can come from explicit args, manifest, or stdout markers/JSON.
    post = run_guardrail('post_agent_run', post_agent_context(args, proc, started_at, stdout_path, stderr_path, contract), persist_db=args.persist_db)
    result['post_agent_run'] = post
    if not post.get('ok'):
        result['blocked_by'] = 'post_agent_run'
        result['agent_run_update'] = _update_agent_run_if_possible(agent_run_id, status='failed', exit_code=proc.returncode, final_message=stdout_text[-2000:], error_message='post_agent_run guardrail blocked completion', contract=contract)
        result['failure_record'] = _mark_task_failed_if_possible(args, reason='post_agent_run guardrail blocked completion', metadata={'blocked_by': 'post_agent_run', 'agent': args.profile, 'task_type': args.task_type, 'guardrail': post, 'artifact_contract': contract})
        print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
        return 1
    result['artifact_index'] = _record_artifacts_if_possible(args, post_result=post, contract=contract, agent_run_id=agent_run_id)
    result['ok'] = proc.returncode == 0 and result['artifact_index'].get('ok', True)
    status = 'success' if result['ok'] else 'failed'
    result['agent_run_update'] = _update_agent_run_if_possible(agent_run_id, status=status, exit_code=proc.returncode, final_message=stdout_text[-2000:], error_message=None if result['ok'] else 'subprocess non-zero or artifact indexing failed', contract=contract)
    if not result['ok']:
        result['failure_record'] = _mark_task_failed_if_possible(args, reason='agent subprocess returned non-zero or artifact indexing failed after guardrail pass', metadata={'blocked_by': 'subprocess_or_artifact_index', 'agent': args.profile, 'task_type': args.task_type, 'exit_code': proc.returncode, 'artifact_index': result.get('artifact_index'), 'artifact_contract': contract})
    print(json.dumps(result, ensure_ascii=False, indent=2, default=str))
    return 0 if result['ok'] else proc.returncode or 1


def build_parser():
    p = argparse.ArgumentParser(description='Dispatch Ohya agent with seo-guardrail hooks')
    p.add_argument('--profile', required=True)
    p.add_argument('--task-type', required=True)
    p.add_argument('--task-id', required=True)
    p.add_argument('--slug')
    p.add_argument('--post-id')
    p.add_argument('--prompt', required=True)
    p.add_argument('--source-text')
    p.add_argument('--expected-output')
    p.add_argument('--audit-json')
    p.add_argument('--max-turns', type=int, default=120)
    p.add_argument('--timeout', type=int, default=600)
    p.add_argument('--persist-db', action='store_true')
    p.add_argument('--dry-run', action='store_true')
    p.add_argument('--artifact-type', default='other')
    p.add_argument('--artifact-summary')
    p.add_argument('--artifact-manifest', help='optional JSON manifest with artifacts list')
    p.add_argument('--no-create-followup-on-failure', dest='create_followup_on_failure', action='store_false')
    p.add_argument('--test-command', help='local verification only: run this command instead of Hermes subprocess')
    p.set_defaults(func=cmd_run)
    return p


def main(argv=None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == '__main__':
    raise SystemExit(main())
