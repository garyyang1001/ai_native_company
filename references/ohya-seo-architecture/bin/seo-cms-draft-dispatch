#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-cms-draft-dispatch — 把 article-editor 完成的 patch_plan 派給 cms-draft-executor.

Closed-loop spec ref: §3.2 + §9 (cms-draft wiring + production approval gate)

掃 article-editor refresh/audit 完成、有 patch_plan artifact、但還沒對應 cms_draft 子 task 的，
自動建立 cms_draft 子 task（status=awaiting_approval）+ approval row，等 Gary 在 Telegram approve。

Usage:
  seo-cms-draft-dispatch list                # 看可派但等批的
  seo-cms-draft-dispatch dispatch [--limit N]  # 建 cms_draft 子 task + approval gate（dry-run 預設）

Safety:
  - Read seo_os.tasks / artifacts only
  - Insert seo_os.tasks (status=awaiting_approval) + approvals (status=pending) + workflow_events
  - 不直接 spawn cms-draft-executor（要等 Gary approve 才走 queue-pickup → 派工）
  - 永遠不直接 production write
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path("/Users/garyyang/clients/ohya")
sys.path.insert(0, str(ROOT / "lib"))
import seo_os_db  # noqa: E402


def find_dispatchable_tasks(limit: int) -> list[dict]:
    """Find article-editor tasks done with patch_plan artifact and no existing cms_draft child."""
    rows = seo_os_db.query_json(
        """
        SELECT t.id AS parent_task_id, t.slug, t.url, t.payload_post_id, t.updated_at,
               a.id AS artifact_id, a.path AS patch_plan_path, a.summary AS patch_summary
        FROM seo_os.tasks t
        JOIN seo_os.artifacts a ON a.task_id = t.id AND a.type IN ('patch_plan', 'fix_queue')
        WHERE t.type IN ('refresh', 'audit')
          AND t.status = 'done'
          AND NOT EXISTS (
              SELECT 1 FROM seo_os.tasks c
              WHERE c.parent_task_id = t.id AND c.type = 'cms_draft'
          )
        ORDER BY t.updated_at DESC
        LIMIT %s
        """,
        [limit],
    )
    return rows


def cmd_list(args):
    rows = find_dispatchable_tasks(args.limit)
    print(json.dumps({
        "ok": True, "dispatchable_count": len(rows),
        "tasks": rows, "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def cmd_dispatch(args):
    rows = find_dispatchable_tasks(args.limit)
    created = []
    skipped = []

    import psycopg
    from psycopg.rows import dict_row
    cfg = seo_os_db.get_db_config()

    for r in rows:
        if args.dry_run:
            created.append({
                "parent_task_id": str(r["parent_task_id"]),
                "slug": r["slug"], "patch_plan_path": r["patch_plan_path"],
                "dry_run": True, "would_create": "cms_draft task + approval row",
            })
            continue

        conn = psycopg.connect(cfg.uri, row_factory=dict_row)
        try:
            with conn.cursor() as cur:
                # 1. INSERT cms_draft task (awaiting_approval)
                cur.execute(
                    """
                    INSERT INTO seo_os.tasks
                        (source, type, status, priority, slug, url, payload_post_id,
                         assigned_agent, parent_task_id, input_summary, metadata)
                    VALUES ('priority_scan', 'cms_draft', 'awaiting_approval', 'medium', %s, %s, %s,
                            'cms-draft-executor', %s, %s, %s::jsonb)
                    RETURNING id
                    """,
                    [
                        r["slug"], r.get("url"), r.get("payload_post_id"),
                        r["parent_task_id"],
                        f"從 patch_plan {r['patch_plan_path']} 寫回 Payload draft (post {r.get('payload_post_id') or 'new'})",
                        json.dumps({
                            "phase": "1.9",
                            "patch_plan_artifact_id": str(r["artifact_id"]),
                            "patch_plan_path": r["patch_plan_path"],
                            "parent_refresh_task_id": str(r["parent_task_id"]),
                        }),
                    ],
                )
                cms_task_id = cur.fetchone()["id"]

                # 2. INSERT approval row
                cur.execute(
                    """
                    INSERT INTO seo_os.approvals
                        (task_id, action, risk_level, requested_by,
                         required_approver_type, required_approver_id, status,
                         approval_message, metadata)
                    VALUES (%s, 'create_cms_draft', 'high', 'seo-cms-draft-dispatch',
                            'gary', 'gary', 'pending', %s, %s::jsonb)
                    RETURNING id
                    """,
                    [
                        cms_task_id,
                        f"批准把 patch_plan 寫回 Payload draft：{r['slug']} (post {r.get('payload_post_id') or 'new draft'})",
                        json.dumps({
                            "approval_subtype": "cms_draft_create",
                            "cms_task_id": str(cms_task_id),
                            "slug": r["slug"],
                            "payload_post_id": r.get("payload_post_id"),
                            "patch_plan_path": r["patch_plan_path"],
                            "patch_summary": r.get("patch_summary"),
                        }),
                    ],
                )
                approval_id = cur.fetchone()["id"]

                # 3. INSERT workflow_event
                cur.execute(
                    """
                    INSERT INTO seo_os.workflow_events
                        (task_id, event_type, actor_type, actor_id, message, metadata)
                    VALUES (%s, 'approval_requested', 'system', 'seo-cms-draft-dispatch', %s, %s::jsonb)
                    """,
                    [
                        cms_task_id,
                        f"awaiting_approval for cms_draft on {r['slug']}",
                        json.dumps({"approval_id": str(approval_id), "slug": r["slug"]}),
                    ],
                )
                conn.commit()

                created.append({
                    "cms_task_id": str(cms_task_id),
                    "approval_id": str(approval_id),
                    "slug": r["slug"],
                    "parent_task_id": str(r["parent_task_id"]),
                    "telegram_prompt": (
                        f"📝 patch_plan 完成，要不要寫進 Payload draft？\n"
                        f"slug: `{r['slug']}`\n"
                        f"post_id: {r.get('payload_post_id') or '(new)'}\n"
                        f"patch: {r['patch_plan_path']}\n\n"
                        f"approval_id: `{approval_id}`\n"
                        f"`Approve {approval_id}` 或 `Reject {approval_id}`"
                    ),
                })
        finally:
            conn.close()

    print(json.dumps({
        "ok": True, "dry_run": args.dry_run, "dispatched_count": len(created),
        "skipped": skipped, "created": created, "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def main():
    p = argparse.ArgumentParser()
    sp = p.add_subparsers(dest="cmd", required=True)

    ls = sp.add_parser("list")
    ls.add_argument("--limit", type=int, default=20)
    ls.set_defaults(func=cmd_list)

    dp = sp.add_parser("dispatch")
    dp.add_argument("--limit", type=int, default=5)
    dp.add_argument("--dry-run", action="store_true")
    dp.set_defaults(func=cmd_dispatch)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
