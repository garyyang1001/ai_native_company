#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-guardrail — local-only guardrail evaluator MVP for SEO Growth OS.

MVP boundary:
- reads workflow context JSON from file/stdin
- evaluates deterministic hard-block guardrails
- emits JSON result
- optionally writes local result artifact
- does not call network, DB, Payload, git, deploy, or mutate production state
"""
