#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-performance-compare — 從 performance_snapshots 找出值得 follow-up 的文章.

Usage:
  seo-performance-compare list [--bucket B] [--limit N]
  seo-performance-compare slug <slug>             # 單篇歷史軌跡
  seo-performance-compare summary                  # 整體 bucket 分布

Read-only against seo_os.performance_snapshots.
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path('/Users/garyyang/clients/ohya')
sys.path.insert(0, str(ROOT / 'lib'))
import seo_os_db  # noqa: E402


def cmd_list(args):
    where = ["period_days = %s"]
    params = [args.period]
    if args.bucket:
        where.append("bucket = %s")
        params.append(args.bucket)
    rows = seo_os_db.query_json(
        f"""
        SELECT DISTINCT ON (slug) slug, url, snapshot_date, bucket,
               clicks, impressions, avg_position, priority_score,
               clicks_delta, impressions_delta, position_delta
        FROM seo_os.performance_snapshots
        WHERE {' AND '.join(where)}
        ORDER BY slug, snapshot_date DESC
        """,
        params,
    )
    rows.sort(key=lambda r: -(r.get("priority_score") or 0))
    print(json.dumps({
        "ok": True,
        "filter": {"bucket": args.bucket, "period_days": args.period},
        "count": len(rows[: args.limit]),
        "rows": rows[: args.limit],
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def cmd_slug(args):
    periods = parse_periods(args.periods) if hasattr(args, 'periods') and args.periods else None
    where = "WHERE slug=%s"
    params = [args.slug]
    if periods:
        where += " AND period_days = ANY(%s)"
        params.append(periods)
    rows = seo_os_db.query_json(
        f"""
        SELECT snapshot_date, period_days, clicks, impressions, ctr, avg_position,
               clicks_delta, impressions_delta, position_delta, bucket, priority_score
        FROM seo_os.performance_snapshots
        {where} ORDER BY snapshot_date DESC, period_days
        """,
        params,
    )
    print(json.dumps({
        "ok": True, "slug": args.slug, "periods": periods, "history": rows,
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def parse_periods(value: str | None) -> list[int] | None:
    if not value:
        return None
    return [int(p.strip()) for p in value.split(',') if p.strip()]


def cmd_trend(args):
    periods = parse_periods(args.periods) or [30, 60, 90, 180, 365]
    rows = seo_os_db.query_json(
        """
        SELECT DISTINCT ON (period_days) period_days, snapshot_date, clicks, impressions, ctr, avg_position, bucket, priority_score
        FROM seo_os.performance_snapshots
        WHERE slug=%s AND period_days = ANY(%s)
        ORDER BY period_days, snapshot_date DESC
        """,
        [args.slug, periods],
    )
    by_period = {int(r["period_days"]): r for r in rows}
    trend = []
    for prev, cur in zip(periods, periods[1:]):
        a, b = by_period.get(prev), by_period.get(cur)
        if not a or not b:
            continue
        trend.append({
            "from_period": prev,
            "to_period": cur,
            "clicks_delta": (b.get("clicks") or 0) - (a.get("clicks") or 0),
            "impressions_delta": (b.get("impressions") or 0) - (a.get("impressions") or 0),
            "position_delta": round(float(b.get("avg_position") or 0) - float(a.get("avg_position") or 0), 3),
        })
    print(json.dumps({"ok": True, "slug": args.slug, "periods": periods, "latest_by_period": rows, "trend": trend, "secret_redacted": True}, ensure_ascii=False, indent=2, default=str))


def cmd_summary(args):
    rows = seo_os_db.query_json(
        """
        SELECT bucket, count(*) AS n
        FROM (
            SELECT DISTINCT ON (slug) slug, bucket
            FROM seo_os.performance_snapshots
            WHERE period_days=%s
            ORDER BY slug, snapshot_date DESC
        ) latest
        GROUP BY bucket ORDER BY n DESC
        """,
        [args.period],
    )
    print(json.dumps({
        "ok": True, "period_days": args.period, "summary": rows, "total_articles": sum(r["n"] for r in rows),
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def main():
    p = argparse.ArgumentParser()
    sp = p.add_subparsers(dest="cmd", required=True)

    lp = sp.add_parser("list")
    lp.add_argument("--bucket", choices=["healthy", "decaying", "almost_there", "stale", "zombie", "unranked", "new", "needs_review"])
    lp.add_argument("--limit", type=int, default=20)
    lp.add_argument("--period", type=int, default=90, help="snapshot period_days to list; default 90")
    lp.set_defaults(func=cmd_list)

    sg = sp.add_parser("slug")
    sg.add_argument("slug")
    sg.add_argument("--periods", help="comma-separated period_days filter, e.g. 30,60,90,180,365")
    sg.set_defaults(func=cmd_slug)

    tr = sp.add_parser("trend")
    tr.add_argument("slug")
    tr.add_argument("--periods", default="30,60,90,180,365")
    tr.set_defaults(func=cmd_trend)

    sm = sp.add_parser("summary")
    sm.add_argument("--period", type=int, default=90, help="snapshot period_days to summarize; default 90")
    sm.set_defaults(func=cmd_summary)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
