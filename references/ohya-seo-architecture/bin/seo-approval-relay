#!/Users/garyyang/clients/ohya/venv/bin/python
"""seo-approval-relay — closed-loop §5 approval gate handler.

Closed-loop spec ref: §5 (approval gate workflow)

Usage:
  seo-approval-relay create <plan-json-path> [--default-top N]
      → INSERT seo_os.approvals (action=topic_approval, status=pending)
      → 輸出 markdown preview + approval_id；caller (cron prompt) 用
        send_message tool 推到 Telegram。

  seo-approval-relay execute <approval-id> [--top N]
      → 觸發於 Gary 在 Telegram 回 "Approve <id> [top=N]" 後。
      → 跑 seo-next-task-rule create --top N
      → 標 approval status=approved + decided_at
      → 寫 workflow_events approval_approved

  seo-approval-relay reject <approval-id> [--reason ...]
      → 標 approval status=rejected

  seo-approval-relay list
      → 列 status=pending 的 approval

Safety:
  - Read-only / write-local-only against seo_os schema.
  - Never touches Payload / Zeabur / git / production.
  - approval_id is UUID — no leaked secret.
"""
from __future__ import annotations

import argparse
import json
import subprocess
import sys
from pathlib import Path

ROOT = Path("/Users/garyyang/clients/ohya")
sys.path.insert(0, str(ROOT / "lib"))
import seo_os_db  # noqa: E402

NEXT_TASK_RULE = ROOT / "bin" / "seo-next-task-rule"


def _format_preview_markdown(plan: list[dict]) -> str:
    """Convert next-task-rule plan output to a Telegram-friendly markdown preview."""
    if not plan:
        return "無建議派工任務。"

    by_bucket: dict[str, list] = {}
    for p in plan:
        by_bucket.setdefault(p["bucket"], []).append(p)

    lines = []
    lines.append(f"**🔔 SEO 修文建議（{len(plan)} 個 candidate）**\n")

    bucket_order = ["decaying", "stale", "almost_there", "zombie", "unranked", "needs_review"]
    bucket_emoji = {
        "decaying": "🔴", "stale": "🟡", "almost_there": "🟠",
        "zombie": "⚪", "unranked": "❔", "needs_review": "🔍",
    }

    for b in bucket_order:
        items = by_bucket.get(b, [])
        if not items:
            continue
        lines.append(f"\n{bucket_emoji.get(b, '·')} **{b}** ({len(items)} 篇)")
        for p in items[:5]:
            score = float(p.get("priority_score") or 0)
            slug = p.get("slug", "")[:48]
            agent = p.get("proposed_agent", "?")
            lines.append(f"  • `{slug}` → {agent}（score {score:.0f}）")
        if len(items) > 5:
            lines.append(f"  • ... 另 {len(items) - 5} 篇")

    return "\n".join(lines)


def cmd_create(args):
    plan_path = Path(args.plan_json)
    if not plan_path.exists():
        print(json.dumps({"ok": False, "error": f"plan file not found: {plan_path}"}, ensure_ascii=False))
        sys.exit(1)

    plan_data = json.loads(plan_path.read_text())
    plan = plan_data.get("plan", [])
    creatable_plan = [p for p in plan if p.get("would_create")]

    preview = _format_preview_markdown(creatable_plan)
    default_top = args.default_top or len(creatable_plan)

    # INSERT approval row + workflow_event in one transaction (manual via psycopg)
    import psycopg
    from psycopg.rows import dict_row
    cfg = seo_os_db.get_db_config()
    conn = psycopg.connect(cfg.uri, row_factory=dict_row)
    try:
        with conn.cursor() as cur:
            cur.execute(
                """
                INSERT INTO seo_os.approvals
                    (action, risk_level, requested_by, required_approver_type, required_approver_id,
                     status, approval_message, metadata)
                VALUES ('topic_approval', 'medium', 'cron-job', 'gary', 'gary', 'pending', %s, %s::jsonb)
                RETURNING id
                """,
                [
                    f"SEO closed-loop next_task batch — {len(creatable_plan)} candidate(s) ready to create",
                    json.dumps({
                        "approval_subtype": "next_task_batch",
                        "default_top": default_top,
                        "candidate_count": len(creatable_plan),
                        "candidates": [
                            {
                                "slug": p["slug"], "bucket": p["bucket"],
                                "priority_score": float(p.get("priority_score") or 0),
                                "proposed_task_type": p["proposed_task_type"],
                                "proposed_agent": p["proposed_agent"],
                            }
                            for p in creatable_plan
                        ],
                        "plan_source_file": str(plan_path),
                    }),
                ],
            )
            approval_id = cur.fetchone()["id"]

            cur.execute(
                """
                INSERT INTO seo_os.workflow_events
                    (event_type, actor_type, actor_id, message, metadata)
                VALUES ('approval_requested', 'system', 'seo-approval-relay', %s, %s::jsonb)
                """,
                [
                    f"approval_requested for next_task_batch (approval_id={approval_id})",
                    json.dumps({"approval_id": str(approval_id), "candidate_count": len(creatable_plan)}),
                ],
            )
            conn.commit()
    finally:
        conn.close()

    telegram_msg = (
        f"{preview}\n\n"
        f"━━━━━━━━━━━━━━━\n"
        f"📋 approval_id: `{approval_id}`\n\n"
        f"回覆方式（複製其中一個）：\n"
        f"`Approve {approval_id}` — 全部建（{len(creatable_plan)} 個）\n"
        f"`Approve {approval_id} top=5` — 只建前 5 個\n"
        f"`Reject {approval_id}` — 全部拒絕"
    )

    print(json.dumps({
        "ok": True,
        "approval_id": str(approval_id),
        "candidate_count": len(creatable_plan),
        "telegram_message": telegram_msg,
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def _approve_topic_batch(approval_id, metadata, top_override):
    """action='topic_approval' → 跑 seo-next-task-rule create --top N."""
    top_n = top_override or metadata.get("default_top") or 5
    result = subprocess.run(
        [str(NEXT_TASK_RULE), "create", "--top", str(top_n)],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return {"ok": False, "error": "next-task-rule create failed", "stderr": result.stderr[:500]}
    create_output = json.loads(result.stdout)
    return {
        "ok": True, "subtype": "topic_batch",
        "approved_top_n": top_n,
        "created_count": create_output.get("created_count", 0),
        "created_tasks": create_output.get("created", []),
        "audit_extra": {"approved_top_n": top_n, "created_task_count": create_output.get("created_count", 0)},
        "event_message": f"approved next_task_batch — {create_output.get('created_count', 0)} task(s) created",
    }


def _approve_cms_draft(approval_id, metadata, top_override):
    """action='create_cms_draft' → 標 cms_draft task 從 awaiting_approval 變 pending."""
    cms_task_id = metadata.get("cms_task_id")
    if not cms_task_id:
        return {"ok": False, "error": "approval metadata missing cms_task_id"}

    rows = seo_os_db.query_json(
        """
        UPDATE seo_os.tasks
        SET status = 'pending',
            updated_at = now(),
            metadata = metadata || jsonb_build_object(
                'approval_id', %s::text,
                'approval_action', %s::text,
                'approved_payload_post_id', %s::text
            )
        WHERE id = %s AND status = 'awaiting_approval'
        RETURNING id, slug, type
        """,
        [str(approval_id), "create_cms_draft", metadata.get("payload_post_id"), cms_task_id],
    )
    if not rows:
        return {"ok": False, "error": f"cms task not found / not awaiting_approval: {cms_task_id}"}

    return {
        "ok": True, "subtype": "cms_draft",
        "cms_task_id": str(cms_task_id),
        "approval_action": "create_cms_draft",
        "slug": rows[0]["slug"],
        "now_status": "pending (queue-pickup will dispatch cms-draft-executor)",
        "audit_extra": {
            "unblocked_cms_task_id": str(cms_task_id),
            "approval_id": str(approval_id),
            "approval_action": "create_cms_draft",
        },
        "event_message": f"approved cms_draft on {rows[0]['slug']} → queued for cms-draft-executor",
    }


# Action dispatcher
APPROVAL_ROUTERS = {
    "topic_approval": _approve_topic_batch,
    "create_cms_draft": _approve_cms_draft,
}


def cmd_execute(args):
    """Called when Gary types 'Approve <id> [top=N]' in Telegram."""
    approval_id = args.approval_id

    rows = seo_os_db.query_json(
        "SELECT id, action, status, metadata FROM seo_os.approvals WHERE id = %s",
        [approval_id],
    )
    if not rows:
        print(json.dumps({"ok": False, "error": f"approval not found: {approval_id}"}, ensure_ascii=False))
        sys.exit(1)
    approval = rows[0]
    if approval["status"] != "pending":
        print(json.dumps({"ok": False, "error": f"approval already {approval['status']}"}, ensure_ascii=False))
        sys.exit(1)

    action = approval["action"]
    router = APPROVAL_ROUTERS.get(action)
    if not router:
        print(json.dumps({"ok": False, "error": f"no router for approval action: {action}"}, ensure_ascii=False))
        sys.exit(1)

    metadata = approval["metadata"] if isinstance(approval["metadata"], dict) else json.loads(approval["metadata"] or "{}")
    routed = router(approval_id, metadata, args.top)
    if not routed.get("ok"):
        print(json.dumps(routed, ensure_ascii=False))
        sys.exit(1)

    # Mark approval approved + write event
    import psycopg
    from psycopg.rows import dict_row
    cfg = seo_os_db.get_db_config()
    conn = psycopg.connect(cfg.uri, row_factory=dict_row)
    try:
        with conn.cursor() as cur:
            cur.execute(
                """
                UPDATE seo_os.approvals
                SET status = 'approved', decided_at = now(),
                    metadata = metadata || %s::jsonb
                WHERE id = %s
                """,
                [json.dumps(routed.get("audit_extra", {})), approval_id],
            )
            cur.execute(
                """
                INSERT INTO seo_os.workflow_events
                    (event_type, actor_type, actor_id, message, metadata)
                VALUES ('approval_approved', 'gary', 'gary', %s, %s::jsonb)
                """,
                [
                    routed.get("event_message", f"approved {action}"),
                    json.dumps({"approval_id": str(approval_id), "action": action, **routed.get("audit_extra", {})}),
                ],
            )
            conn.commit()
    finally:
        conn.close()

    print(json.dumps({
        "ok": True, "approval_id": str(approval_id), "action": action,
        **{k: v for k, v in routed.items() if k not in ("audit_extra", "event_message", "ok")},
        "secret_redacted": True,
    }, ensure_ascii=False, indent=2, default=str))


def cmd_reject(args):
    approval_id = args.approval_id
    reason = args.reason or "rejected by Gary in Telegram"

    rows = seo_os_db.query_json(
        "SELECT id, status FROM seo_os.approvals WHERE id = %s",
        [approval_id],
    )
    if not rows or rows[0]["status"] != "pending":
        print(json.dumps({"ok": False, "error": "approval not found or not pending"}, ensure_ascii=False))
        sys.exit(1)

    seo_os_db.execute(
        """
        UPDATE seo_os.approvals
        SET status = 'rejected', decided_at = now(),
            metadata = metadata || %s::jsonb
        WHERE id = %s
        """,
        [json.dumps({"rejection_reason": reason}), approval_id],
    )
    seo_os_db.execute(
        """
        INSERT INTO seo_os.workflow_events
            (event_type, actor_type, actor_id, message, metadata)
        VALUES ('approval_rejected', 'gary', 'gary', %s, %s::jsonb)
        """,
        [f"rejected next_task_batch: {reason}", json.dumps({"approval_id": str(approval_id), "reason": reason})],
    )

    print(json.dumps({"ok": True, "approval_id": str(approval_id), "status": "rejected"}, ensure_ascii=False, indent=2, default=str))


def cmd_list(args):
    rows = seo_os_db.query_json(
        """
        SELECT id, created_at, action, status, approval_message, metadata
        FROM seo_os.approvals
        WHERE status = 'pending' AND action = 'topic_approval'
        ORDER BY created_at DESC LIMIT %s
        """,
        [args.limit],
    )
    print(json.dumps({"ok": True, "count": len(rows), "pending": rows, "secret_redacted": True}, ensure_ascii=False, indent=2, default=str))


def main():
    p = argparse.ArgumentParser()
    sp = p.add_subparsers(dest="cmd", required=True)

    cr = sp.add_parser("create", help="Create approval gate from plan JSON")
    cr.add_argument("plan_json", help="Path to next-task-rule plan output JSON")
    cr.add_argument("--default-top", type=int, help="Default top N when Gary approves without explicit number")
    cr.set_defaults(func=cmd_create)

    ex = sp.add_parser("execute", help="Approve and trigger task creation")
    ex.add_argument("approval_id")
    ex.add_argument("--top", type=int, help="Override approved top N")
    ex.set_defaults(func=cmd_execute)

    rj = sp.add_parser("reject", help="Reject approval")
    rj.add_argument("approval_id")
    rj.add_argument("--reason")
    rj.set_defaults(func=cmd_reject)

    ls = sp.add_parser("list", help="List pending approvals")
    ls.add_argument("--limit", type=int, default=20)
    ls.set_defaults(func=cmd_list)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
